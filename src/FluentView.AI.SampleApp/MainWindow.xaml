<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FluentView.AI.SampleApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FluentView.AI.SampleApp"
    xmlns:fv="using:FluentView.AI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FluentView.AI Sample">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Provider Settings Bar -->
        <Border Grid.Row="0"
                Padding="12,8"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ComboBox x:Name="ProviderCombo"
                          SelectedIndex="0"
                          Width="130"
                          SelectionChanged="ProviderCombo_SelectionChanged">
                    <ComboBoxItem Content="Mock" />
                    <ComboBoxItem Content="Claude" />
                    <ComboBoxItem Content="OpenAI" />
                    <ComboBoxItem Content="Ollama" />
                    <ComboBoxItem Content="Gemini" />
                    <ComboBoxItem Content="Groq" />
                </ComboBox>

                <PasswordBox x:Name="ApiKeyBox"
                             PlaceholderText="API Key"
                             Width="280"
                             Visibility="Collapsed" />

                <ComboBox x:Name="ModelCombo"
                          IsEditable="True"
                          PlaceholderText="Model"
                          Width="220" />

                <Button x:Name="RefreshModelsButton"
                        Content="&#xE72C;"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        ToolTipService.ToolTip="Refresh Models"
                        Click="OnRefreshModels" />

                <Button x:Name="BrowseModelsButton"
                        Content="Browse..."
                        Visibility="Collapsed"
                        Click="OnBrowseModels" />

                <Button Content="Apply"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnApplyProvider" />

                <Button Content="Clear"
                        Click="OnClearChat" />

                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="12"
                           Opacity="0.8" />
            </StackPanel>
        </Border>

        <fv:ChatPanel x:Name="ChatPanel"
                      Grid.Row="1"
                      Placeholder="Type a message..." />
    </Grid>
</Window>
