<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluentView.AI.SampleApp.Settings.PromptPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="18,12,18,12"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="Prompt_Title" Text="System Prompt"
                       Style="{StaticResource SubtitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="18,12">
            <StackPanel Spacing="16">

                <TextBlock x:Uid="Prompt_Description" Text="Configure the system prompt sent to AI models."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.7" />

                <TextBox x:Uid="Prompt_Placeholder" x:Name="SystemPromptBox"
                         PlaceholderText="Enter system prompt..."
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="200"
                         TextChanged="OnSystemPromptChanged" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
