<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluentView.AI.SampleApp.Settings.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="18,12,18,12"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="About_Title" Text="About"
                       Style="{StaticResource SubtitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="18,12">
            <StackPanel Spacing="16">

                <!-- App Info -->
                <StackPanel Spacing="4">
                    <TextBlock Text="FluentView.AI"
                               Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="VersionText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.7" />
                </StackPanel>

                <TextBlock x:Uid="About_Description" Text="AI Chat UI Control for WinUI 3."
                           TextWrapping="Wrap" />

                <TextBlock x:Uid="About_Providers" Text="Supports Claude, OpenAI, Ollama, Gemini, Groq and more."
                           TextWrapping="Wrap"
                           Opacity="0.7" />

                <!-- License -->
                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4" />

                <TextBlock x:Uid="About_License" Text="License"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock x:Uid="About_MITLicense" Text="MIT License" />

                <!-- Links -->
                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4" />

                <TextBlock x:Uid="About_Links" Text="Links"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <HyperlinkButton x:Uid="About_GitHubRepo" Content="GitHub Repository"
                                 NavigateUri="https://github.com/diluculo/FluentView.AI" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
