<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluentView.AI.SampleApp.Settings.AdvancedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="18,12,18,12"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="Advanced_Title" Text="Advanced"
                       Style="{StaticResource SubtitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="18,12">
            <StackPanel Spacing="16">

                <!-- Language -->
                <TextBlock x:Uid="Advanced_Language" Text="Language"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <TextBlock x:Uid="Advanced_LanguageDescription"
                           Text="Override the system default language. Changes take effect after restarting the app."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.7" />

                <ComboBox x:Name="LanguagePicker"
                          Width="220"
                          SelectionChanged="OnLanguageChanged" />

                <InfoBar x:Name="LanguageRestartInfo"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Warning"
                         Title="Restart required"
                         Message="Please restart the app to apply the language change." />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
