<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FieldCure.AssistStudio.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///AssistStudio.Controls/Themes/Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ComposeBar -->
    <Style TargetType="local:ComposeBar">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:ComposeBar">
                    <Border
                        x:Name="PART_ContainerBorder"
                        MaxWidth="800"
                        HorizontalAlignment="Stretch"
                        Margin="12,0,12,12"
                        Padding="12"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        Translation="0,0,16">
                        <Grid RowSpacing="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: Edit banner (visible only in edit mode) -->
                            <Grid
                                x:Name="PART_EditBanner"
                                Grid.Row="0"
                                Visibility="Collapsed"
                                Padding="8,4"
                                Margin="0,0,0,4"
                                CornerRadius="4"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    Glyph="&#xE70F;"
                                    FontSize="12"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    x:Name="PART_EditBannerLabel"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button
                                    x:Name="PART_EditBannerCancelButton"
                                    Grid.Column="2"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    Padding="4">
                                    <FontIcon Glyph="&#xE711;" FontSize="10" />
                                </Button>
                            </Grid>

                            <!-- Row 1: Audio reject bar (visible when send is blocked by audio capability mismatch) -->
                            <Grid
                                x:Name="PART_AudioRejectBar"
                                Grid.Row="1"
                                Visibility="Collapsed"
                                Padding="8,4"
                                Margin="0,0,0,4"
                                CornerRadius="4"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    Glyph="&#xE946;"
                                    FontSize="12"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    x:Name="PART_AudioRejectLabel"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    TextWrapping="Wrap"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Button
                                        x:Name="PART_AudioRejectCancelButton"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Padding="8,2" />
                                    <Button
                                        x:Name="PART_AudioRejectSendButton"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="8,2" />
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Attachment previews -->
                            <local:AttachmentPreviewBar x:Name="PART_PreviewBar" Grid.Row="2" />

                            <!-- Row 3: TextBox -->
                            <TextBox
                                x:Name="PART_MessageTextBox"
                                Grid.Row="3"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                FontSize="15"
                                MaxHeight="120"
                                MinHeight="44"
                                Padding="12,8"
                                BorderThickness="0"
                                Background="Transparent"
                                PlaceholderText="{TemplateBinding Placeholder}">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                    <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                    <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                </TextBox.Resources>
                            </TextBox>

                            <!-- Row 4: Toolbar -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    Grid.Column="0" Orientation="Horizontal" Spacing="4"
                                    VerticalAlignment="Center">
                                    <Button
                                        x:Name="PART_AttachButton"
                                        AutomationProperties.AutomationId="ComposeBarAttachButton"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Padding="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    </Button>
                                    <Button
                                        x:Name="PART_ToolButton"
                                        AutomationProperties.AutomationId="ComposeBarToolButton"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Padding="6"
                                        Visibility="Collapsed">
                                        <FontIcon Glyph="&#xE90F;" FontSize="14" />
                                    </Button>
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                    VerticalAlignment="Center">
                                    <ComboBox
                                        x:Name="PART_ProfileComboBox"
                                        AutomationProperties.AutomationId="ComposeBarProfileSelector"
                                        MinWidth="100"
                                        VerticalAlignment="Center"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Padding="8,4" />
                                    <ComboBox
                                        x:Name="PART_PresetComboBox"
                                        AutomationProperties.AutomationId="ComposeBarPresetSelector"
                                        MinWidth="120"
                                        VerticalAlignment="Center"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Padding="8,4" />

                                    <!-- Send button (visible when idle) -->
                                    <Button
                                        x:Name="PART_SendButton"
                                        AutomationProperties.AutomationId="ComposeBarSendButton"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        VerticalAlignment="Center"
                                        Padding="6">
                                        <FontIcon Glyph="&#xE7EB;" FontSize="16" />
                                    </Button>
                                    
                                    <!-- Stop button (visible when streaming) -->
                                    <Button
                                        x:Name="PART_StopButton"
                                        AutomationProperties.AutomationId="ComposeBarStopButton"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        VerticalAlignment="Center"
                                        Padding="6"
                                        Visibility="Collapsed">
                                        <FontIcon Glyph="&#xE71A;" FontSize="16" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
