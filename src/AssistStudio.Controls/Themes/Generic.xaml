<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FieldCure.AssistStudio.Controls">

    <!-- Shared Styles -->
    <Style x:Key="SubtleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Opacity">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="0.4" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- AttachmentPreviewBar -->
    <Style TargetType="local:AttachmentPreviewBar">
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:AttachmentPreviewBar">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Disabled">
                        <StackPanel x:Name="PART_ItemsPanel"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Padding="4" />
                    </ScrollViewer>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- InputContainer -->
    <Style TargetType="local:InputContainer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:InputContainer">
                    <Border x:Name="PART_ContainerBorder"
                            MaxWidth="800"
                            HorizontalAlignment="Stretch"
                            Margin="12,0,12,12"
                            Padding="12"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Translation="0,0,16">
                        <Grid RowSpacing="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: Attachment previews -->
                            <local:AttachmentPreviewBar x:Name="PART_PreviewBar" Grid.Row="0" />

                            <!-- Row 1: TextBox -->
                            <TextBox x:Name="PART_MessageTextBox"
                                     Grid.Row="1"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MaxHeight="120"
                                     MinHeight="32"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     PlaceholderText="{TemplateBinding Placeholder}">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                    <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                    <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                </TextBox.Resources>
                            </TextBox>

                            <!-- Row 2: Toolbar -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                                    <Button x:Name="PART_AttachButton"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    </Button>
                                    <Button x:Name="PART_SummarizeButton"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="6">
                                        <FontIcon Glyph="&#xEB78;" FontSize="14" />
                                    </Button>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center">
                                    <ComboBox x:Name="PART_ProfileComboBox"
                                              MinWidth="100"
                                              VerticalAlignment="Center"
                                              BorderThickness="0"
                                              Background="Transparent"
                                              Padding="8,4" />
                                    <ComboBox x:Name="PART_PresetComboBox"
                                              MinWidth="120"
                                              VerticalAlignment="Center"
                                              BorderThickness="0"
                                              Background="Transparent"
                                              Padding="8,4" />
                                    <!-- Send button (visible when idle) -->
                                    <Button x:Name="PART_SendButton"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            VerticalAlignment="Center"
                                            Padding="6">
                                        <FontIcon Glyph="&#xE7EB;" FontSize="16" />
                                    </Button>
                                    <!-- Stop button (visible when streaming) -->
                                    <Button x:Name="PART_StopButton"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            VerticalAlignment="Center"
                                            Padding="6"
                                            Visibility="Collapsed">
                                        <FontIcon Glyph="&#xE71A;" FontSize="16" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToolApprovalPanel -->
    <Style TargetType="local:ToolApprovalPanel">
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:ToolApprovalPanel">
                    <Border MaxWidth="800"
                            HorizontalAlignment="Stretch"
                            Margin="12,0,12,12"
                            Padding="16"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Translation="0,0,16">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: Header -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE90F;" FontSize="16"
                                              Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                    <TextBlock x:Name="PART_PromptText"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <Button x:Name="PART_ExpandButton"
                                        Grid.Column="2"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Padding="6"
                                        VerticalAlignment="Center">
                                    <FontIcon x:Name="PART_ExpandIcon" Glyph="&#xE70E;" FontSize="12" />
                                </Button>
                            </Grid>

                            <!-- Row 1: Arguments preview (collapsed by default) -->
                            <ScrollViewer x:Name="PART_ArgumentsContainer"
                                          Grid.Row="1"
                                          Visibility="Collapsed"
                                          MaxHeight="200"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <Border Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                        CornerRadius="4" Padding="12">
                                    <TextBlock x:Name="PART_ArgumentsText"
                                               FontFamily="Consolas, Courier New, monospace"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               IsTextSelectionEnabled="True" />
                                </Border>
                            </ScrollViewer>

                            <!-- Row 2: Action buttons -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Spacing="8">
                                <Button x:Name="PART_RejectButton"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Padding="12,6"
                                        Content="Reject" />
                                <Button x:Name="PART_ApproveButton"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="16,6"
                                        Content="Allow" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ChatPanel -->
    <Style TargetType="local:ChatPanel">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:ChatPanel">
                    <Grid x:Name="PART_RootGrid" AllowDrop="True">
                        <!-- Empty state: input centered vertically -->
                        <Grid x:Name="PART_EmptyStatePanel"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Stretch"
                              Padding="24">
                            <StackPanel x:Name="PART_EmptyStateContent" VerticalAlignment="Center" MaxWidth="680">
                                <local:InputContainer x:Name="PART_InputArea"
                                                      HorizontalAlignment="Stretch"
                                                      Placeholder="{TemplateBinding Placeholder}" />
                            </StackPanel>
                        </Grid>

                        <!-- Chat layout (initially collapsed) -->
                        <Grid x:Name="PART_ChatLayout" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel x:Name="PART_TitleBar" Grid.Row="0" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="8" Padding="20,14,20,10">
                                    <TextBlock x:Name="PART_TitleText"
                                               Style="{StaticResource SubtitleTextBlockStyle}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="PART_TitleEditButton"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="4"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                    </Button>
                                    <Button x:Name="PART_TitleRefreshButton"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="4"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE777;" FontSize="12" />
                                    </Button>
                                </StackPanel>
                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            </StackPanel>

                            <WebView2 x:Name="PART_ChatWebView" Grid.Row="1" DefaultBackgroundColor="Transparent" IsTabStop="False" />

                            <!-- Tool approval panel (shown in place of InputContainer when confirmation needed) -->
                            <local:ToolApprovalPanel x:Name="PART_ToolApprovalPanel" Grid.Row="2" />
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
