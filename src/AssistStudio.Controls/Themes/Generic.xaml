<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FieldCure.AssistStudio.Controls">

    <!--
        SubtleButtonStyle — back-port from WinAppSDK 1.8 generic.xaml.
        Controls targets WinAppSDK 1.7 where SubtleButtonStyle is not built-in.
        When Controls upgrades to 1.8+, this entire block (ThemeDictionaries + Style)
        can be removed in favour of the framework-provided version.
    -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <StaticResource x:Key="SubtleButtonBackground" ResourceKey="SubtleFillColorTransparentBrush" />
            <StaticResource x:Key="SubtleButtonBackgroundPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
            <StaticResource x:Key="SubtleButtonBackgroundPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="SubtleButtonBackgroundDisabled" ResourceKey="SubtleFillColorTransparentBrush" />
            <StaticResource x:Key="SubtleButtonForeground" ResourceKey="TextFillColorPrimaryBrush" />
            <StaticResource x:Key="SubtleButtonForegroundPointerOver" ResourceKey="TextFillColorPrimaryBrush" />
            <StaticResource x:Key="SubtleButtonForegroundPressed" ResourceKey="TextFillColorSecondaryBrush" />
            <StaticResource x:Key="SubtleButtonForegroundDisabled" ResourceKey="TextFillColorDisabledBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrush" ResourceKey="SubtleFillColorTransparentBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrushPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrushPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrushDisabled" ResourceKey="SubtleFillColorTransparentBrush" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <StaticResource x:Key="SubtleButtonBackground" ResourceKey="SubtleFillColorTransparentBrush" />
            <StaticResource x:Key="SubtleButtonBackgroundPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
            <StaticResource x:Key="SubtleButtonBackgroundPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="SubtleButtonBackgroundDisabled" ResourceKey="SubtleFillColorTransparentBrush" />
            <StaticResource x:Key="SubtleButtonForeground" ResourceKey="TextFillColorPrimaryBrush" />
            <StaticResource x:Key="SubtleButtonForegroundPointerOver" ResourceKey="TextFillColorPrimaryBrush" />
            <StaticResource x:Key="SubtleButtonForegroundPressed" ResourceKey="TextFillColorSecondaryBrush" />
            <StaticResource x:Key="SubtleButtonForegroundDisabled" ResourceKey="TextFillColorDisabledBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrush" ResourceKey="SubtleFillColorTransparentBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrushPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrushPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrushDisabled" ResourceKey="SubtleFillColorTransparentBrush" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <StaticResource x:Key="SubtleButtonBackground" ResourceKey="SystemControlBackgroundBaseLowBrush" />
            <StaticResource x:Key="SubtleButtonBackgroundPointerOver" ResourceKey="SystemColorHighlightTextColorBrush" />
            <StaticResource x:Key="SubtleButtonBackgroundPressed" ResourceKey="SystemColorHighlightTextColorBrush" />
            <StaticResource x:Key="SubtleButtonBackgroundDisabled" ResourceKey="SystemControlBackgroundBaseLowBrush" />
            <StaticResource x:Key="SubtleButtonForeground" ResourceKey="SystemColorButtonTextColorBrush" />
            <StaticResource x:Key="SubtleButtonForegroundPointerOver" ResourceKey="SystemControlHighlightBaseHighBrush" />
            <StaticResource x:Key="SubtleButtonForegroundPressed" ResourceKey="SystemControlHighlightBaseHighBrush" />
            <StaticResource x:Key="SubtleButtonForegroundDisabled" ResourceKey="SystemControlDisabledBaseMediumLowBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrush" ResourceKey="SystemControlForegroundTransparentBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrushPointerOver" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrushPressed" ResourceKey="SystemColorHighlightTextColorBrush" />
            <StaticResource x:Key="SubtleButtonBorderBrushDisabled" ResourceKey="SystemControlDisabledTransparentBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Shared Styles -->
    <Style x:Key="SubtleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource SubtleButtonBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource SubtleButtonForeground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource SubtleButtonBorderBrush}" />
        <Setter Property="BackgroundSizing" Value="InnerBorderEdge" />
        <Setter Property="BorderThickness" Value="{ThemeResource ButtonBorderThemeThickness}" />
        <Setter Property="Padding" Value="{StaticResource ButtonPadding}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{ThemeResource ContentControlThemeFontFamily}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="FontSize" Value="{ThemeResource ControlContentThemeFontSize}" />
        <Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
        <Setter Property="FocusVisualMargin" Value="-3" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter x:Name="ContentPresenter"
                                      Background="{TemplateBinding Background}"
                                      Foreground="{TemplateBinding Foreground}"
                                      BackgroundSizing="{TemplateBinding BackgroundSizing}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      ContentTransitions="{TemplateBinding ContentTransitions}"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      AutomationProperties.AccessibilityView="Raw">
                        <ContentPresenter.BackgroundTransition>
                            <BrushTransition Duration="0:0:0.083" />
                        </ContentPresenter.BackgroundTransition>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleButtonBackgroundPointerOver}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleButtonBorderBrushPointerOver}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleButtonForegroundPointerOver}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleButtonBackgroundPressed}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleButtonBorderBrushPressed}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleButtonForegroundPressed}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleButtonBackgroundDisabled}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleButtonBorderBrushDisabled}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource SubtleButtonForegroundDisabled}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </ContentPresenter>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- AttachmentPreviewBar -->
    <Style TargetType="local:AttachmentPreviewBar">
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:AttachmentPreviewBar">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Disabled">
                        <StackPanel x:Name="PART_ItemsPanel"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Padding="4" />
                    </ScrollViewer>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComposeBar -->
    <Style TargetType="local:ComposeBar">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:ComposeBar">
                    <Border x:Name="PART_ContainerBorder"
                            MaxWidth="800"
                            HorizontalAlignment="Stretch"
                            Margin="12,0,12,12"
                            Padding="12"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Translation="0,0,16">
                        <Grid RowSpacing="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: Attachment previews -->
                            <local:AttachmentPreviewBar x:Name="PART_PreviewBar" Grid.Row="0" />

                            <!-- Row 1: TextBox -->
                            <TextBox x:Name="PART_MessageTextBox"
                                     Grid.Row="1"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     FontSize="15"
                                     MaxHeight="120"
                                     MinHeight="44"
                                     Padding="12,8"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     PlaceholderText="{TemplateBinding Placeholder}">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                    <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                    <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                </TextBox.Resources>
                            </TextBox>

                            <!-- Row 2: Toolbar -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                                    <Button x:Name="PART_AttachButton"
                                            x:Uid="ComposeBar_Attach"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    </Button>
                                    <Button x:Name="PART_ToolButton"
                                            x:Uid="ComposeBar_Tools"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="6"
                                            Visibility="Collapsed">
                                        <FontIcon Glyph="&#xE90F;" FontSize="14" />
                                    </Button>
                                    <Button x:Name="PART_SummarizeButton"
                                            x:Uid="ComposeBar_Summarize"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="6">
                                        <FontIcon Glyph="&#xEB78;" FontSize="14" />
                                    </Button>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center">
                                    <ComboBox x:Name="PART_ProfileComboBox"
                                              MinWidth="100"
                                              VerticalAlignment="Center"
                                              BorderThickness="0"
                                              Background="Transparent"
                                              Padding="8,4" />
                                    <ComboBox x:Name="PART_PresetComboBox"
                                              MinWidth="120"
                                              VerticalAlignment="Center"
                                              BorderThickness="0"
                                              Background="Transparent"
                                              Padding="8,4" />
                                    <!-- Send button (visible when idle) -->
                                    <Button x:Name="PART_SendButton"
                                            x:Uid="ComposeBar_Send"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            VerticalAlignment="Center"
                                            Padding="6">
                                        <FontIcon Glyph="&#xE7EB;" FontSize="16" />
                                    </Button>
                                    <!-- Stop button (visible when streaming) -->
                                    <Button x:Name="PART_StopButton"
                                            x:Uid="ComposeBar_Stop"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            VerticalAlignment="Center"
                                            Padding="6"
                                            Visibility="Collapsed">
                                        <FontIcon Glyph="&#xE71A;" FontSize="16" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToolApprovalPanel -->
    <Style TargetType="local:ToolApprovalPanel">
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:ToolApprovalPanel">
                    <Border MaxWidth="800"
                            HorizontalAlignment="Stretch"
                            Margin="12,0,12,12"
                            Padding="16"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Translation="0,0,16">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: Header -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE90F;" FontSize="16"
                                              Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                    <TextBlock x:Name="PART_PromptText"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <Button x:Name="PART_ExpandButton"
                                        x:Uid="ToolApproval_Expand"
                                        Grid.Column="2"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Padding="6"
                                        VerticalAlignment="Center">
                                    <FontIcon x:Name="PART_ExpandIcon" Glyph="&#xE70E;" FontSize="12" />
                                </Button>
                            </Grid>

                            <!-- Row 1: Arguments preview (collapsed by default) -->
                            <ScrollViewer x:Name="PART_ArgumentsContainer"
                                          Grid.Row="1"
                                          Visibility="Collapsed"
                                          MaxHeight="200"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <Border Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                        CornerRadius="4" Padding="12">
                                    <TextBlock x:Name="PART_ArgumentsText"
                                               FontFamily="Consolas, Courier New, monospace"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               IsTextSelectionEnabled="True" />
                                </Border>
                            </ScrollViewer>

                            <!-- Row 2: Action buttons -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Spacing="8">
                                <Button x:Name="PART_RejectButton"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Padding="12,6"
                                        Content="Reject" />
                                <Button x:Name="PART_ApproveButton"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="16,6"
                                        Content="Allow" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ChatPanel -->
    <Style TargetType="local:ChatPanel">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:ChatPanel">
                    <Grid x:Name="PART_RootGrid" AllowDrop="True">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="FolderStates">
                                <VisualState x:Name="NoFolders" />
                                <VisualState x:Name="HasFolders">
                                    <VisualState.Setters>
                                        <Setter Target="PART_FolderIcon.Glyph" Value="&#xE8D5;" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="IndexingStates">
                                <VisualState x:Name="Idle" />
                                <VisualState x:Name="Indexing">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_FolderIcon"
                                            Storyboard.TargetProperty="Opacity"
                                            From="1.0" To="0.3"
                                            Duration="0:0:0.8"
                                            AutoReverse="True" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Title bar: always visible -->
                        <StackPanel x:Name="PART_TitleBar" Grid.Row="0">
                            <Grid Padding="20,14,20,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- Left: title + edit/refresh -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="PART_TitleText"
                                               Style="{StaticResource SubtitleTextBlockStyle}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="PART_TitleEditButton"
                                            x:Uid="ChatPanel_EditTitle"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="4"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                    </Button>
                                    <Button x:Name="PART_TitleRefreshButton"
                                            x:Uid="ChatPanel_RefreshTitle"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="4"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE777;" FontSize="12" />
                                    </Button>
                                </StackPanel>
                                <!-- Right: folder button with indexing animation -->
                                <Button x:Name="PART_TitleFolderButton"
                                        Grid.Column="1"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Padding="4"
                                        VerticalAlignment="Center">
                                    <Button.Flyout>
                                        <Flyout Placement="BottomEdgeAlignedLeft">
                                            <StackPanel MinWidth="300" Spacing="4">
                                                <!-- Workspace Folders header + Add button -->
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="PART_FolderHeaderText"
                                                               Text="Workspace Folders"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <Button x:Name="PART_FolderAddButton"
                                                            Grid.Column="1"
                                                            Style="{StaticResource SubtleButtonStyle}"
                                                            Padding="6,2,6,2"
                                                            VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon Glyph="&#xE710;" FontSize="10" />
                                                            <TextBlock x:Name="PART_FolderAddButtonText"
                                                                       Text="Add Folder" FontSize="12" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>

                                                <!-- Workspace disabled hint -->
                                                <TextBlock x:Name="PART_FolderDisabledHint"
                                                           Text="Enable Workspace in your profile to use these folders."
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           FontSize="12" TextWrapping="Wrap"
                                                           Margin="0,0,0,4" Visibility="Collapsed" />

                                                <!-- Dynamic folder list (populated in code-behind) -->
                                                <StackPanel x:Name="PART_FolderList" Spacing="2" />

                                                <!-- Workspace empty state -->
                                                <TextBlock x:Name="PART_FolderEmpty"
                                                           Text="(empty)"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           FontSize="12" Margin="8,0,0,0" />

                                                <!-- Divider -->
                                                <Rectangle Height="1"
                                                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                           Opacity="0.3" Margin="0,8,0,4" />

                                                <!-- Knowledge Archive header + progress + Set button -->
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="PART_ArchiveHeaderText"
                                                               Text="Knowledge Archive"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <ProgressBar x:Name="PART_ArchiveProgressBar"
                                                                 Grid.Column="1"
                                                                 Margin="8,0,0,0"
                                                                 VerticalAlignment="Center"
                                                                 Minimum="0" Maximum="100"
                                                                 Visibility="Collapsed" />
                                                    <TextBlock x:Name="PART_ArchiveProgressText"
                                                               Grid.Column="2"
                                                               Margin="6,0,0,0"
                                                               FontSize="12"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               VerticalAlignment="Center"
                                                               Visibility="Collapsed" />
                                                    <Button x:Name="PART_ArchiveCancelButton"
                                                            Grid.Column="3"
                                                            Style="{StaticResource SubtleButtonStyle}"
                                                            Padding="4" VerticalAlignment="Center"
                                                            Visibility="Collapsed">
                                                        <FontIcon Glyph="&#xE711;" FontSize="10" />
                                                    </Button>
                                                    <Button x:Name="PART_ArchiveSetButton"
                                                            Grid.Column="4"
                                                            Style="{StaticResource SubtleButtonStyle}"
                                                            Padding="6,2,6,2"
                                                            VerticalAlignment="Center"
                                                            Visibility="Collapsed">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon Glyph="&#xE710;" FontSize="10" />
                                                            <TextBlock x:Name="PART_ArchiveSetButtonText"
                                                                       Text="Set Folder" FontSize="12" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>

                                                <!-- Archive disabled hint -->
                                                <TextBlock x:Name="PART_ArchiveDisabledHint"
                                                           Text="Enable Knowledge Archive in your profile to use this folder."
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           FontSize="12" TextWrapping="Wrap"
                                                           Margin="0,0,0,4" Visibility="Collapsed" />

                                                <!-- Archive folder row (path + reindex/lock + remove) -->
                                                <Grid x:Name="PART_ArchiveFolderRow" Visibility="Collapsed">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="PART_ArchiveFolderText"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontSize="12" Margin="8,0,0,0"
                                                               VerticalAlignment="Center" />
                                                    <Button x:Name="PART_ArchiveReindexButton"
                                                            Grid.Column="1"
                                                            Style="{StaticResource SubtleButtonStyle}"
                                                            Padding="4" VerticalAlignment="Center">
                                                        <FontIcon Glyph="&#xE72C;" FontSize="10" />
                                                    </Button>
                                                    <FontIcon x:Name="PART_ArchiveLockIcon"
                                                              Grid.Column="2"
                                                              Glyph="&#xE72E;"
                                                              FontSize="10"
                                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                              VerticalAlignment="Center"
                                                              Visibility="Collapsed" />
                                                    <Button x:Name="PART_ArchiveRemoveButton"
                                                            Grid.Column="3"
                                                            Style="{StaticResource SubtleButtonStyle}"
                                                            Padding="4" VerticalAlignment="Center">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="10" />
                                                    </Button>
                                                </Grid>

                                                <!-- Archive empty state -->
                                                <TextBlock x:Name="PART_ArchiveEmpty"
                                                           Text="(empty)"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           FontSize="12" Margin="8,0,0,0" />
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                    <FontIcon x:Name="PART_FolderIcon" Glyph="&#xE838;" FontSize="14" />
                                </Button>
                            </Grid>
                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        </StackPanel>

                        <!-- Empty state: input centered vertically -->
                        <Grid x:Name="PART_EmptyStatePanel"
                              Grid.Row="1"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Stretch"
                              Padding="24">
                            <StackPanel x:Name="PART_EmptyStateContent" VerticalAlignment="Center" MaxWidth="680">
                                <local:ComposeBar x:Name="PART_InputArea"
                                                      HorizontalAlignment="Stretch"
                                                      Placeholder="{TemplateBinding Placeholder}" />
                            </StackPanel>
                        </Grid>

                        <!-- Chat layout (initially collapsed) -->
                        <Grid x:Name="PART_ChatLayout" Grid.Row="1" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <WebView2 x:Name="PART_ChatWebView" Grid.Row="0" DefaultBackgroundColor="Transparent" IsTabStop="False" />

                            <!-- Search bar overlay (right-aligned in WebView2 area) -->
                            <Border x:Name="PART_SearchBar" Grid.Row="0"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right"
                                    Margin="0,8,28,0"
                                    Padding="6,4"
                                    CornerRadius="6"
                                    Background="{ThemeResource SolidBackgroundFillColorQuarternaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Translation="0,0,32"
                                    Visibility="Collapsed">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBox x:Name="PART_SearchTextBox"
                                             x:Uid="Chat_SearchTextBox"
                                             Width="200" Height="28"
                                             Padding="8,4"
                                             FontSize="13"
                                             BorderThickness="0"
                                             VerticalAlignment="Center">
                                        <TextBox.Resources>
                                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                            <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                            <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <TextBlock x:Name="PART_SearchCount"
                                               VerticalAlignment="Center"
                                               Margin="2,0"
                                               Opacity="0.6"
                                               FontSize="12" />
                                    <Button x:Name="PART_SearchPrevButton"
                                            Width="28" Height="28"
                                            MinWidth="28" MinHeight="28"
                                            Padding="0"
                                            x:Uid="Chat_SearchPrevButton"
                                            Style="{StaticResource SubtleButtonStyle}">
                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE70E;" FontSize="11" />
                                    </Button>
                                    <Button x:Name="PART_SearchNextButton"
                                            Width="28" Height="28"
                                            MinWidth="28" MinHeight="28"
                                            Padding="0"
                                            x:Uid="Chat_SearchNextButton"
                                            Style="{StaticResource SubtleButtonStyle}">
                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE70D;" FontSize="11" />
                                    </Button>
                                    <Button x:Name="PART_SearchCloseButton"
                                            Width="28" Height="28"
                                            MinWidth="28" MinHeight="28"
                                            Padding="0"
                                            x:Uid="Chat_SearchCloseButton"
                                            Style="{StaticResource SubtleButtonStyle}">
                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE711;" FontSize="11" />
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Tool approval panel (shown in place of ComposeBar when confirmation needed) -->
                            <local:ToolApprovalPanel x:Name="PART_ToolApprovalPanel" Grid.Row="1" />
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
