<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0-windows10.0.19041.0;net9.0-windows10.0.19041.0</TargetFrameworks>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>FieldCure.AssistStudio.Controls</RootNamespace>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>12</LangVersion>
    <Version>0.19.0</Version>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- NuGet Package Metadata -->
    <PackageId>FieldCure.AssistStudio.Controls.WinUI</PackageId>
    <Description>AI Chat UI Controls for WinUI 3. Supports Claude, OpenAI, Gemini, Ollama and more.</Description>
    <Authors>Jong Hyun Kim</Authors>
    <Company>Fieldcure Co., Ltd.</Company>
    <Copyright>Copyright (c) 2026 Fieldcure Co., Ltd.</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/fieldcure/fieldcure-assiststudio</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>ai;chat;winui;winui3;controls;claude;openai;gemini;ollama;webview2</PackageTags>
    <PackageReleaseNotes>v0.19.0: HTML/JSX artifact preview — sandboxed iframe with React 18 + Tailwind + 17 vendored libs (recharts, lucide-react, three, d3, lodash, mathjs, papaparse, Chart.js, Tone, SheetJS, mammoth, TensorFlow.js, prop-types, …) served from a strict CDN whitelist, esm.sh fallback for unmapped imports, shadcn/ui inline shim, hooks-as-globals, and self-render acceptance. ModelPicker control with multi-model-per-provider integrated into ComposeBar and the auxiliary task selector. Continue split into its own bubble (ChatMessage.IsHidden + IsContinuation) with a reload "truncated" hint (IsTruncated) replacing the phantom Continue button. Document and audio attachment chips. Gemini inline image rendering persisted through .astx. Elicitation SubmitMode for external dialog hosting + required-field validation. Explicit AutomationProperties.Name on icon-only buttons. JSX import rewriter consolidated into one multi-form pass (default+named/namespace, multi-line bodies). Chat column widened 800→1100px, artifact iframe 400→540px. Public-repo prep: Korean strings translated to English. Rebuilt against Core 0.19.0 + Ai.Providers 0.7.0.</PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <None Include="icon.png" Pack="true" PackagePath="" />
    <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.7.*" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.*" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.*" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AssistStudio.Core\AssistStudio.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PRIResource Include="Strings\**\*.resw" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Rendering\Resources\chat.html" />
    <EmbeddedResource Include="Rendering\Resources\vendor\marked.min.js" />
    <EmbeddedResource Include="Rendering\Resources\vendor\highlight.min.js" />
    <EmbeddedResource Include="Rendering\Resources\vendor\katex.min.js" />
    <EmbeddedResource Include="Rendering\Resources\vendor\mermaid.min.js" />
    <EmbeddedResource Include="Rendering\Resources\vendor\katex.min.css" />
    <EmbeddedResource Include="Rendering\Resources\vendor\katex-fonts\*.woff2" />
    <!--
      Artifact-preview JSX runtime — full bundle vendoring of the 17 JS libraries
      Anthropic's Claude.ai loads in its artifact iframe. Embedded so the preview
      works in air-gapped environments (data-sovereignty story for medical / IP
      customers) and so old .astx conversations re-render identically years later
      against the same locked versions. See WebViewChatRenderer.OnWebResourceRequested
      for the assiststudio.vendor virtual host that serves these.
    -->
    <EmbeddedResource Include="Rendering\Resources\vendor\jsx\*.js" />
  </ItemGroup>

</Project>
