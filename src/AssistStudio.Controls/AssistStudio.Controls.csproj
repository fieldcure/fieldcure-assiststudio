<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0-windows10.0.19041.0;net9.0-windows10.0.19041.0</TargetFrameworks>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>FieldCure.AssistStudio.Controls</RootNamespace>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>12</LangVersion>
    <Version>0.20.0</Version>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- NuGet Package Metadata -->
    <PackageId>FieldCure.AssistStudio.Controls.WinUI</PackageId>
    <Description>AI Chat UI Controls for WinUI 3. Supports Claude, OpenAI, Gemini, Ollama and more.</Description>
    <Authors>Jong Hyun Kim</Authors>
    <Company>Fieldcure Co., Ltd.</Company>
    <Copyright>Copyright (c) 2026 Fieldcure Co., Ltd.</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/fieldcure/fieldcure-assiststudio</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>ai;chat;winui;winui3;controls;claude;openai;gemini;ollama;webview2</PackageTags>
    <PackageReleaseNotes>v0.20.0: New public API — ChatPanel.GroupDisplayNameResolver and ComposeBar.GroupDisplayNameResolver (Func&lt;string, string?&gt;) so hosts can map raw ProviderType IDs (e.g., "Custom_046A…") to readable display names (e.g., "MiniMax") in the model picker group headers and the selected-model summary; falls back to the raw ProviderType (Mock → "demo") when unset. Greeting picks one of seven localized variants per render (en-US + ko-KR). Empty-state header now falls back to the greeting whenever Title is empty — switching the model mid-conversation no longer clobbers an auto-generated/user-edited title, and a transient pre-first-reply state no longer flashes the model id. Thinking block anchors above the streamed assistant text (matches tool-block placement). ChatPanel.Dispose now resets imperative per-tab state (current turn, edit-mode flag, draft text, attachments, workspace folders, KB selection, conversation-active flag) so a recycled container can't leak the previous tab's UI state into the next. Rebuilt against same Core 0.19.1 + Ai.Providers 0.7.2.</PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <None Include="icon.png" Pack="true" PackagePath="" />
    <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.7.*" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.*" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.*" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AssistStudio.Core\AssistStudio.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PRIResource Include="Strings\**\*.resw" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Rendering\Resources\chat.html" />
    <EmbeddedResource Include="Rendering\Resources\vendor\marked.min.js" />
    <EmbeddedResource Include="Rendering\Resources\vendor\highlight.min.js" />
    <EmbeddedResource Include="Rendering\Resources\vendor\katex.min.js" />
    <EmbeddedResource Include="Rendering\Resources\vendor\mermaid.min.js" />
    <EmbeddedResource Include="Rendering\Resources\vendor\katex.min.css" />
    <EmbeddedResource Include="Rendering\Resources\vendor\katex-fonts\*.woff2" />
    <!--
      Artifact-preview JSX runtime — full bundle vendoring of the 17 JS libraries
      Anthropic's Claude.ai loads in its artifact iframe. Embedded so the preview
      works in air-gapped environments (data-sovereignty story for medical / IP
      customers) and so old .astx conversations re-render identically years later
      against the same locked versions. See WebViewChatRenderer.OnWebResourceRequested
      for the assiststudio.vendor virtual host that serves these.
    -->
    <EmbeddedResource Include="Rendering\Resources\vendor\jsx\*.js" />
  </ItemGroup>

</Project>
