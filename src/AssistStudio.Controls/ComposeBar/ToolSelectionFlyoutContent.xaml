<UserControl
    x:Class="FieldCure.AssistStudio.Controls.ToolSelectionFlyoutContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///AssistStudio.Controls/Themes/Shared.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <StackPanel x:Name="PART_ListLayout" Padding="4">
            <ScrollViewer
                MaxHeight="400"
                Padding="0,0,8,0">
                <ItemsControl
                    x:Name="PART_ItemsControl"
                    ItemTemplate="{StaticResource CheckBoxItemTemplate}" />
            </ScrollViewer>

            <StackPanel
                x:Name="PART_FooterPanel"
                Spacing="4"
                Padding="4,0,4,4">
                <Rectangle
                    x:Name="PART_Separator"
                    Height="1"
                    Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Opacity="0.3" />
                <HyperlinkButton
                    x:Name="PART_ToggleAllLink"
                    Padding="0"
                    FontSize="12" />
            </StackPanel>
        </StackPanel>

        <StackPanel
            x:Name="PART_EmptyStatePanel"
            Visibility="Collapsed"
            Spacing="4"
            Padding="8"
            MaxWidth="240">
            <TextBlock
                x:Name="PART_EmptyText"
                TextWrapping="Wrap"
                Opacity="0.6"
                FontSize="12" />
        </StackPanel>
    </Grid>
</UserControl>
