<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FluentView.AI.Controls.InputContainer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:FluentView.AI.Controls"
    mc:Ignorable="d"
    AllowDrop="True"
    DragOver="OnDragOver"
    Drop="OnDrop">

    <UserControl.Resources>
        <ThemeShadow x:Name="InputShadow" />
    </UserControl.Resources>

    <Border x:Name="ContainerBorder"
            MaxWidth="800"
            HorizontalAlignment="Stretch"
            Margin="12,0,12,12"
            Padding="12"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Shadow="{StaticResource InputShadow}"
            Translation="0,0,16">

        <Grid RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: Attachment previews -->
            <local:AttachmentPreviewBar x:Name="PreviewBar" Grid.Row="0" />

            <!-- Row 1: TextBox (borderless, auto-resize) -->
            <TextBox x:Name="MessageTextBox"
                     Grid.Row="1"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MaxHeight="120"
                     MinHeight="32"
                     BorderThickness="0"
                     Background="Transparent"
                     PlaceholderText="{x:Bind Placeholder, Mode=OneWay}"
                     PreviewKeyDown="MessageTextBox_PreviewKeyDown"
                     Paste="MessageTextBox_Paste" />

            <!-- Row 2: Toolbar -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: Action buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                    <Button x:Name="AttachButton"
                            x:Uid="InputContainer_Attach"
                            Style="{StaticResource SubtleButtonStyle}"
                            Click="AttachButton_Click"
                            Padding="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                    </Button>
                    <Button x:Name="SummarizeButton"
                            x:Uid="InputContainer_Summarize"
                            Style="{StaticResource SubtleButtonStyle}"
                            Click="SummarizeButton_Click"
                            Padding="6">
                        <FontIcon Glyph="&#xEB78;" FontSize="14" />
                    </Button>
                </StackPanel>

                <!-- Right: Prompt preset + Provider selector -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center">
                    <ComboBox x:Name="PromptPresetComboBox"
                              MinWidth="100"
                              SelectionChanged="PromptPresetComboBox_SelectionChanged"
                              VerticalAlignment="Center"
                              BorderThickness="0"
                              Background="Transparent"
                              Padding="8,4" />
                    <ComboBox x:Name="PresetComboBox"
                              MinWidth="120"
                              SelectionChanged="PresetComboBox_SelectionChanged"
                              VerticalAlignment="Center"
                              BorderThickness="0"
                              Background="Transparent"
                              Padding="8,4" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
