<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FluentView.AI.Controls.ChatPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:FluentView.AI.Controls"
    mc:Ignorable="d"
    Loaded="OnLoaded">

    <Grid x:Name="RootGrid">
        <!-- Empty state: input centered vertically -->
        <Grid x:Name="EmptyStatePanel"
              VerticalAlignment="Center"
              HorizontalAlignment="Stretch"
              Padding="24">
            <StackPanel x:Name="EmptyStateContent" VerticalAlignment="Center" MaxWidth="680">
                <local:InputContainer x:Name="InputArea"
                                      HorizontalAlignment="Stretch"
                                      Placeholder="{x:Bind Placeholder, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- Chat layout (initially collapsed) -->
        <Grid x:Name="ChatLayout" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <WebView2 x:Name="ChatWebView" Grid.Row="0" DefaultBackgroundColor="Transparent" />
        </Grid>
    </Grid>
</UserControl>
