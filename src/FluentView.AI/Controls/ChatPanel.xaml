<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FluentView.AI.Controls.ChatPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:FluentView.AI.Controls"
    mc:Ignorable="d"
    Loaded="OnLoaded">

    <Grid x:Name="RootGrid" AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop">
        <!-- Empty state: input centered vertically -->
        <Grid x:Name="EmptyStatePanel"
              VerticalAlignment="Center"
              HorizontalAlignment="Stretch"
              Padding="24">
            <StackPanel x:Name="EmptyStateContent" VerticalAlignment="Center" MaxWidth="680">
                <local:InputContainer x:Name="InputArea"
                                      HorizontalAlignment="Stretch"
                                      Placeholder="{x:Bind Placeholder, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- Chat layout (initially collapsed) -->
        <Grid x:Name="ChatLayout" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="TitleBar" Grid.Row="0" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8" Padding="20,14,20,10">
                    <TextBlock x:Name="TitleText"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"
                               VerticalAlignment="Center" />
                    <Button x:Name="TitleEditButton"
                            Click="OnTitleEditClick"
                            Padding="4"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE70F;" FontSize="12" />
                    </Button>
                </StackPanel>
                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
            </StackPanel>

            <WebView2 x:Name="ChatWebView" Grid.Row="1" DefaultBackgroundColor="Transparent" />
        </Grid>
    </Grid>
</UserControl>
