<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="AssistView.Studio.Dialogs.FirstRunDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Welcome to FluentView.AI"
    CloseButtonText="Skip"
    DefaultButton="Primary">

    <StackPanel Spacing="16" MinWidth="450">

        <!-- Step 1: Welcome + Hardware -->
        <StackPanel x:Name="Step1Panel" Spacing="12">
            <TextBlock Text="Let's set up your AI assistant."
                       Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap" />

            <StackPanel Spacing="4" Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4">
                <TextBlock Text="Your Hardware" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock x:Name="HwGpuText" FontSize="13" />
                <TextBlock x:Name="HwRamText" FontSize="13" />
            </StackPanel>
        </StackPanel>

        <!-- Step 2: Provider Choice -->
        <StackPanel x:Name="Step2Panel" Visibility="Collapsed" Spacing="12">
            <TextBlock Text="How would you like to use AI?"
                       Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap" />

            <RadioButtons x:Name="ProviderChoice">
                <RadioButton x:Name="RadioLocal" Content="Local (Ollama) — Free, runs on your PC" />
                <RadioButton x:Name="RadioCloud" Content="Cloud API — Claude, OpenAI, Gemini, etc." />
            </RadioButtons>
        </StackPanel>

        <!-- Step 3: Ollama Setup -->
        <StackPanel x:Name="Step3Panel" Visibility="Collapsed" Spacing="12">
            <TextBlock Text="Ollama Setup"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ProgressRing x:Name="OllamaSetupSpinner" IsActive="False"
                              Width="16" Height="16" Visibility="Collapsed" />
                <TextBlock x:Name="OllamaSetupStatus" FontSize="13" />
            </StackPanel>

            <!-- Model recommendation -->
            <StackPanel x:Name="ModelRecommendPanel" Visibility="Collapsed" Spacing="8">
                <TextBlock Text="Recommended model for your hardware:"
                           FontSize="13" Opacity="0.8" />
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Name="RecommendedModelText"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button x:Name="DownloadModelButton" Content="Download"
                            Click="OnDownloadModel" />
                </StackPanel>
                <StackPanel x:Name="DownloadProgressPanel" Visibility="Collapsed" Spacing="4">
                    <TextBlock x:Name="DownloadStatus" FontSize="12" />
                    <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="100" />
                </StackPanel>
            </StackPanel>

            <!-- Install link -->
            <StackPanel x:Name="OllamaInstallPanel" Visibility="Collapsed" Spacing="4">
                <TextBlock Text="Ollama is not installed on your system."
                           FontSize="13" />
                <HyperlinkButton Content="Download Ollama"
                                 NavigateUri="https://ollama.com/download" />
                <TextBlock Text="After installing, restart this app."
                           FontSize="12" Opacity="0.6" />
            </StackPanel>
        </StackPanel>

        <!-- Step 3 (Cloud): API Key -->
        <StackPanel x:Name="Step3CloudPanel" Visibility="Collapsed" Spacing="12">
            <TextBlock Text="Cloud Provider Setup"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock Text="You can configure API keys in Settings > Models after setup."
                       FontSize="13" Opacity="0.8" TextWrapping="Wrap" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
