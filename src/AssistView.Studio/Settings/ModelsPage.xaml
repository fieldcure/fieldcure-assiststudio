<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistView.Studio.Settings.ModelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="Models_Title" Text="Models"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20,20,20,0">
            <StackPanel Spacing="24" Padding="0,0,0,80">

                <!-- ============================== -->
                <!-- Cloud Inference (SaaS) Section -->
                <!-- ============================== -->
                <TextBlock x:Uid="Models_CloudSection" Text="Cloud Inference (SaaS)"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <!-- Anthropic Claude -->
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Anthropic Claude"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="ClaudeStatusText"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- Input state (no key) -->
                    <Grid x:Name="ClaudeKeyInputPanel" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="ClaudeApiKeyBox"
                                     x:Uid="Models_ApiKeyBox"
                                     PlaceholderText="API Key" />
                        <Button Grid.Column="1"
                                x:Uid="Models_AddKeyButton"
                                Content="Add"
                                Click="OnAddClaudeKey" />
                    </Grid>
                    <!-- Display state (key exists) -->
                    <Grid x:Name="ClaudeKeyDisplayPanel" Visibility="Collapsed" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ClaudeMaskedKeyText"
                                   VerticalAlignment="Center" Opacity="0.7"
                                   IsTextSelectionEnabled="True" />
                        <Button Grid.Column="1"
                                x:Uid="Models_RemoveKey"
                                ToolTipService.ToolTip="Remove Key"
                                Click="OnRemoveClaudeKey" Padding="6,4">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      Glyph="&#xE74D;" FontSize="14" />
                        </Button>
                    </Grid>
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Models_DefaultModel" Text="Default Model" FontSize="12" Opacity="0.7" />
                        <ComboBox x:Name="ClaudeModelCombo"
                                  x:Uid="Models_ModelNotAvailable"
                                  HorizontalAlignment="Stretch"
                                  IsEnabled="False"
                                  PlaceholderText="Not available" />
                    </StackPanel>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- OpenAI -->
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="OpenAI"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="OpenAIStatusText"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid x:Name="OpenAIKeyInputPanel" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="OpenAIApiKeyBox"
                                     PlaceholderText="API Key" />
                        <Button Grid.Column="1"
                                x:Uid="Models_AddKeyButton"
                                Content="Add"
                                Click="OnAddOpenAIKey" />
                    </Grid>
                    <Grid x:Name="OpenAIKeyDisplayPanel" Visibility="Collapsed" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OpenAIMaskedKeyText"
                                   VerticalAlignment="Center" Opacity="0.7"
                                   IsTextSelectionEnabled="True" />
                        <Button Grid.Column="1"
                                x:Uid="Models_RemoveKey"
                                ToolTipService.ToolTip="Remove Key"
                                Click="OnRemoveOpenAIKey" Padding="6,4">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      Glyph="&#xE74D;" FontSize="14" />
                        </Button>
                    </Grid>
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Models_DefaultModel" Text="Default Model" FontSize="12" Opacity="0.7" />
                        <ComboBox x:Name="OpenAIModelCombo"
                                  HorizontalAlignment="Stretch"
                                  IsEnabled="False"
                                  PlaceholderText="Not available" />
                    </StackPanel>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- Google Gemini -->
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Google Gemini"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="GeminiStatusText"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid x:Name="GeminiKeyInputPanel" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="GeminiApiKeyBox"
                                     PlaceholderText="API Key" />
                        <Button Grid.Column="1"
                                x:Uid="Models_AddKeyButton"
                                Content="Add"
                                Click="OnAddGeminiKey" />
                    </Grid>
                    <Grid x:Name="GeminiKeyDisplayPanel" Visibility="Collapsed" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="GeminiMaskedKeyText"
                                   VerticalAlignment="Center" Opacity="0.7"
                                   IsTextSelectionEnabled="True" />
                        <Button Grid.Column="1"
                                x:Uid="Models_RemoveKey"
                                ToolTipService.ToolTip="Remove Key"
                                Click="OnRemoveGeminiKey" Padding="6,4">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      Glyph="&#xE74D;" FontSize="14" />
                        </Button>
                    </Grid>
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Models_DefaultModel" Text="Default Model" FontSize="12" Opacity="0.7" />
                        <ComboBox x:Name="GeminiModelCombo"
                                  HorizontalAlignment="Stretch"
                                  IsEnabled="False"
                                  PlaceholderText="Not available" />
                    </StackPanel>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- Groq -->
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Groq"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="GroqStatusText"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid x:Name="GroqKeyInputPanel" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="GroqApiKeyBox"
                                     PlaceholderText="API Key" />
                        <Button Grid.Column="1"
                                x:Uid="Models_AddKeyButton"
                                Content="Add"
                                Click="OnAddGroqKey" />
                    </Grid>
                    <Grid x:Name="GroqKeyDisplayPanel" Visibility="Collapsed" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="GroqMaskedKeyText"
                                   VerticalAlignment="Center" Opacity="0.7"
                                   IsTextSelectionEnabled="True" />
                        <Button Grid.Column="1"
                                x:Uid="Models_RemoveKey"
                                ToolTipService.ToolTip="Remove Key"
                                Click="OnRemoveGroqKey" Padding="6,4">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      Glyph="&#xE74D;" FontSize="14" />
                        </Button>
                    </Grid>
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Models_DefaultModel" Text="Default Model" FontSize="12" Opacity="0.7" />
                        <ComboBox x:Name="GroqModelCombo"
                                  HorizontalAlignment="Stretch"
                                  IsEnabled="False"
                                  PlaceholderText="Not available" />
                    </StackPanel>
                </StackPanel>

                <!-- ============================== -->
                <!-- Local Inference (On-Device)    -->
                <!-- ============================== -->
                <Rectangle Height="2" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

                <TextBlock x:Uid="Models_LocalSection" Text="Local Inference (On-Device)"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <!-- Ollama -->
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Ollama"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="OllamaStatusText"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center" />
                        <ProgressRing x:Name="OllamaSpinner" IsActive="False"
                                      Width="16" Height="16" Visibility="Collapsed" />
                        <Button x:Name="OllamaRefreshButton"
                                Padding="4"
                                x:Uid="Models_RefreshStatus"
                                ToolTipService.ToolTip="Check status"
                                Click="OnCheckOllama">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      Glyph="&#xE72C;" FontSize="12" />
                        </Button>
                    </StackPanel>

                    <!-- Install guidance -->
                    <StackPanel x:Name="OllamaInstallPanel" Visibility="Collapsed" Spacing="2">
                        <HyperlinkButton x:Uid="Models_DownloadOllama"
                                         Content="Download Ollama"
                                         NavigateUri="https://ollama.com/download"
                                         Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                         Padding="0" />
                    </StackPanel>

                    <!-- Start button -->
                    <Button x:Name="StartOllamaButton"
                            x:Uid="Models_StartOllama"
                            Content="Start Ollama" Click="OnStartOllama"
                            Visibility="Collapsed" />

                    <!-- Browse models -->
                    <Button x:Name="BrowseModelsButton"
                            x:Uid="Models_BrowsePullModels"
                            Content="Browse &amp; Pull Models" Click="OnBrowseOllamaModels"
                            Visibility="Collapsed" />

                    <!-- Download Progress -->
                    <StackPanel x:Name="PullProgressPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock x:Name="PullProgressStatus" FontSize="12" />
                        <ProgressBar x:Name="PullProgressBar" Minimum="0" Maximum="100" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Models_DefaultModel" Text="Default Model" FontSize="12" Opacity="0.7" />
                        <ComboBox x:Name="OllamaModelCombo"
                                  HorizontalAlignment="Stretch"
                                  IsEnabled="False"
                                  PlaceholderText="Not available"
                                  SelectionChanged="OnOllamaModelChanged" />
                    </StackPanel>
                </StackPanel>

                <!-- ============================== -->
                <!-- Default Provider               -->
                <!-- ============================== -->
                <Rectangle Height="2" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

                <TextBlock x:Uid="Models_DefaultProvider" Text="Default Provider"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <ComboBox x:Name="DefaultProviderCombo"
                          HorizontalAlignment="Stretch"
                          SelectionChanged="OnDefaultProviderChanged" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
