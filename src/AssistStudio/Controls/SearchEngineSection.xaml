<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AssistStudio.Controls.SearchEngineSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AssistStudio.Controls">

    <controls:CollapsibleSection x:Name="Section" IsExpanded="False" IsCompact="True"
                                 Expanded="OnSectionExpanded">
        <controls:CollapsibleSection.Body>
            <StackPanel x:Name="ContentPanel" Spacing="10" />
        </controls:CollapsibleSection.Body>
    </controls:CollapsibleSection>
</UserControl>
