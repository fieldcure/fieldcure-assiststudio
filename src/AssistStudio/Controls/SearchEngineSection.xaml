<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AssistStudio.Controls.SearchEngineSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AssistStudio.Controls">

    <controls:CollapsibleSection
        x:Name="Section"
        IsCompact="True"
        IsExpanded="False"
        Expanded="OnSectionExpanded">
        <controls:CollapsibleSection.Body>
            <StackPanel Spacing="10">

                <!-- Runtime-swap hint — tools can change the engine mid-conversation. -->
                <TextBlock
                    x:Name="RuntimeHintText"
                    Visibility="Collapsed"
                    TextWrapping="Wrap"
                    FontSize="12"
                    Opacity="0.7"
                    Margin="0,0,0,4" />

                <!-- Active engine selector -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        x:Name="ActiveEngineLabel"
                        VerticalAlignment="Center" />
                    <ComboBox
                        Grid.Column="1"
                        x:Name="EngineCombo"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="OnEngineComboSelectionChanged" />
                </Grid>

                <!-- Divider between selection and key-management sections -->
                <Border
                    Height="1"
                    Margin="0,4,0,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- API key management -->
                <TextBlock
                    x:Name="ApiKeysHeader"
                    FontWeight="Bold" />

                <ItemsControl x:Name="PaidEnginesList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="controls:PaidEngineRowViewModel">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    Text="{x:Bind DisplayName}"
                                    VerticalAlignment="Center"
                                    Margin="0" />

                                <PasswordBox
                                    Grid.Column="1"
                                    PlaceholderText="{x:Bind ApiKeyPlaceholder}"
                                    Password="{x:Bind ApiKey, Mode=OneWay}"
                                    PasswordRevealMode="Hidden"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    PasswordChanged="OnPaidEngineKeyChanged" />

                                <Button
                                    Grid.Column="2"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind ClearVisibility, Mode=OneWay}"
                                    Click="OnClearPaidEngine">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind RemoveTooltip}" Placement="Mouse" />
                                    </ToolTipService.ToolTip>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Wolfram|Alpha — independent optional AppID (not part of the engine selector). -->
                <Grid x:Name="WolframRow" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        x:Name="WolframLabel"
                        VerticalAlignment="Center"
                        Margin="0" />

                    <PasswordBox
                        Grid.Column="1"
                        x:Name="WolframKey"
                        PasswordRevealMode="Hidden"
                        HorizontalAlignment="Stretch"
                        PasswordChanged="OnWolframKeyChanged" />

                    <Button
                        Grid.Column="2"
                        x:Name="WolframClearButton"
                        Style="{StaticResource SubtleButtonStyle}"
                        Padding="6"
                        VerticalAlignment="Center"
                        Visibility="Collapsed"
                        Click="OnWolframClear">
                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        <ToolTipService.ToolTip>
                            <ToolTip x:Name="WolframRemoveTooltip" Placement="Mouse" />
                        </ToolTipService.ToolTip>
                    </Button>
                </Grid>
                <TextBlock
                    x:Name="WolframHint"
                    Opacity="0.5"
                    Margin="10,0,0,0"
                    Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>
        </controls:CollapsibleSection.Body>
    </controls:CollapsibleSection>
</UserControl>
