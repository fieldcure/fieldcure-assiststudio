<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AssistStudio.Controls.ScheduleCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PointerEntered="OnCardPointerEntered"
    PointerExited="OnCardPointerExited">

    <Grid Background="Transparent" Padding="0,10,0,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Column 0: task info -->
        <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock x:Name="NameText"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <TextBlock x:Name="DescriptionText"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.7"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />
            <TextBlock x:Name="DetailText"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.5"
                       Visibility="Collapsed" />
        </StackPanel>

        <!-- Column 1: toggle on top, delete below (stacked) -->
        <StackPanel Grid.Column="1"
                    Spacing="4"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">
            <ToggleSwitch x:Name="EnabledToggle"
                          OnContent="" OffContent=""
                          MinWidth="0"
                          Toggled="OnToggled" />

            <Button x:Name="DeleteButton"
                    Padding="6" MinWidth="0" MinHeight="0"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    Style="{ThemeResource SubtleButtonStyle}"
                    Click="OnDeleteClicked">
                <ToolTipService.ToolTip>
                    <ToolTip x:Uid="ScheduleCard_DeleteButtonTip" Placement="Mouse" />
                </ToolTipService.ToolTip>
                <FontIcon Glyph="&#xE74D;" FontSize="12" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
