<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AssistStudio.Controls.ChannelsSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AssistStudio.Controls">

    <controls:CollapsibleSection x:Name="Section" IsExpanded="False" IsCompact="True" Expanded="OnSectionExpanded">
        <controls:CollapsibleSection.Body>
            <StackPanel Spacing="6">
                <!-- Add channel button with type picker -->
                <Button x:Name="AddChannelButton"
                        HorizontalAlignment="Left"
                        Padding="10,4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="12" />
                        <TextBlock x:Name="AddChannelText" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Name="AddSlackItem"     Tag="slack"     Click="OnAddChannelTypeClick" Text="Slack" />
                            <MenuFlyoutItem x:Name="AddDiscordItem"   Tag="discord"   Click="OnAddChannelTypeClick" Text="Discord" />
                            <MenuFlyoutItem x:Name="AddGmailItem"     Tag="gmail"     Click="OnAddChannelTypeClick" Text="Gmail" />
                            <MenuFlyoutItem x:Name="AddNaverItem"     Tag="naver"     Click="OnAddChannelTypeClick" Text="Naver" />
                            <MenuFlyoutItem x:Name="AddSmtpItem"      Tag="smtp"      Click="OnAddChannelTypeClick" Text="SMTP (custom)" />
                            <MenuFlyoutItem x:Name="AddTelegramItem"  Tag="telegram"  Click="OnAddChannelTypeClick" Text="Telegram" />
                            <MenuFlyoutItem x:Name="AddKakaoItem"     Tag="kakaotalk" Click="OnAddChannelTypeClick" Text="KakaoTalk" />
                            <MenuFlyoutItem x:Name="AddMicrosoftItem" Tag="microsoft" Click="OnAddChannelTypeClick" Text="Microsoft (Outlook)" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <!-- Loading indicator -->
                <StackPanel x:Name="LoadingPanel" Orientation="Horizontal" Spacing="8">
                    <ProgressRing IsActive="True" Width="16" Height="16" />
                    <TextBlock
                        x:Name="LoadingText"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Opacity="0.6" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Channel list — data-driven from the Outbox MCP server. -->
                <ItemsControl x:Name="ChannelList" Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="controls:ChannelRowViewModel">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Connected status dot -->
                                <FontIcon
                                    Grid.Column="0"
                                    Glyph="&#xF136;"
                                    FontSize="10"
                                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0" />

                                <!-- Channel type label -->
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind DisplayType}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    VerticalAlignment="Center" />

                                <!-- Channel detail (name / from) -->
                                <TextBlock
                                    Grid.Column="2"
                                    Text="{x:Bind DisplayDetail}"
                                    Opacity="0.7"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis" />

                                <!-- Delete — dispatches to the Outbox CLI remove command. -->
                                <Button
                                    Grid.Column="3"
                                    Padding="6,2,6,2"
                                    Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                    BorderThickness="0"
                                    Tag="{x:Bind Id}"
                                    Click="OnDeleteChannelClick">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind DeleteTooltip}" Placement="Mouse" />
                                    </ToolTipService.ToolTip>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty / error state -->
                <TextBlock
                    x:Name="StatusText"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Opacity="0.5" TextWrapping="Wrap"
                    Visibility="Collapsed" />
            </StackPanel>
        </controls:CollapsibleSection.Body>
    </controls:CollapsibleSection>
</UserControl>
