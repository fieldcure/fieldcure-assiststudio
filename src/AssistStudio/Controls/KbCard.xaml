<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AssistStudio.Controls.KbCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="2" Padding="0,4,0,4">

        <!-- Row 1: Name + Status -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="NameText"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />

            <TextBlock x:Name="StatusText" Grid.Column="1"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Row 2: Stats (conditional) -->
        <TextBlock x:Name="StatsText"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Opacity="0.6"
                   Visibility="Collapsed" />

        <!-- Row 3: Source paths -->
        <TextBlock x:Name="SourcePathsText"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Opacity="0.5"
                   TextTrimming="CharacterEllipsis" />

        <!-- Row 4: Model info (conditional) -->
        <TextBlock x:Name="ModelInfoText"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Opacity="0.45"
                   FontSize="11"
                   Visibility="Collapsed" />

        <!-- Row 4b: Model availability warning -->
        <TextBlock x:Name="ModelWarningText"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   FontSize="11"
                   Foreground="{ThemeResource SystemFillColorCautionBrush}"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <!-- Change summary (shown after check_changes, idle only) -->
        <TextBlock x:Name="ChangeSummaryText"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Margin="0,4,0,0"
                   Visibility="Collapsed" />

        <!-- Indexing state: Progress bar + stop button -->
        <Grid x:Name="IndexingPanel" Margin="0,6,0,0" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressBar x:Name="IndexProgressBar"
                         Maximum="100"
                         VerticalAlignment="Center" />

            <Button x:Name="StopButton" Grid.Column="1"
                    Style="{ThemeResource SubtleButtonStyle}"
                    Padding="6"
                    Margin="8,0,0,0"
                    Click="StopButton_Click">
                <FontIcon Glyph="&#xE71A;" FontSize="14" />
            </Button>
        </Grid>

        <!-- Deferred state: Index now / Cancel scheduled -->
        <Grid x:Name="DeferredPanel" Margin="0,6,0,0" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="IndexNowButton"
                    Style="{ThemeResource SubtleButtonStyle}"
                    Padding="8,4,8,4"
                    FontSize="12"
                    Click="IndexNowButton_Click" />

            <Button x:Name="CancelDeferredButton" Grid.Column="1"
                    Style="{ThemeResource SubtleButtonStyle}"
                    Padding="8,4,8,4"
                    FontSize="12"
                    Margin="8,0,0,0"
                    Click="CancelDeferredButton_Click" />

            <Button x:Name="DeferredDeleteButton" Grid.Column="3"
                    Style="{ThemeResource SubtleButtonStyle}"
                    Padding="6"
                    Click="DeleteButton_Click">
                <FontIcon Glyph="&#xE74D;" FontSize="14" />
            </Button>
        </Grid>

        <!-- Idle state: Action buttons -->
        <Grid x:Name="ActionPanel" Margin="0,6,0,0" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="CheckChangesButton"
                    Style="{ThemeResource SubtleButtonStyle}"
                    Padding="8,4,8,4"
                    FontSize="12"
                    Click="CheckChangesButton_Click" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="SettingsButton"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Padding="6"
                        Click="SettingsButton_Click">
                    <FontIcon Glyph="&#xE70F;" FontSize="14" />
                </Button>
                <Button x:Name="ReindexButton"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Padding="6"
                        Click="ReindexButton_Click">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
                <Button x:Name="DeleteButton"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Padding="6"
                        Click="DeleteButton_Click">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Inline search match area -->
        <StackPanel x:Name="MatchPanel" Visibility="Collapsed" Spacing="4"
                    Margin="0,10,0,0">
            <Rectangle Height="1"
                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Shimmer placeholders during search -->
            <StackPanel x:Name="MatchShimmerPanel" Visibility="Collapsed" Spacing="6"
                        Margin="0,6,0,0" />

            <!-- "No matches" state -->
            <TextBlock x:Name="NoMatchText"
                       Visibility="Collapsed"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.5"
                       Margin="0,4,0,0" />

            <!-- Actual match results -->
            <StackPanel x:Name="MatchResultsPanel" Spacing="2" />
        </StackPanel>

    </StackPanel>
</UserControl>
