<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AssistStudio.Controls.EmbeddingModelSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="12">
        <!-- Embedding model -->
        <StackPanel Spacing="4">
            <TextBlock x:Name="EmbeddingHeader" Opacity="0.8" />
            <StackPanel x:Name="EmbeddingModelPanel" Spacing="6" />
        </StackPanel>

        <!-- Chunk contextualization -->
        <StackPanel Spacing="4">
            <TextBlock x:Name="ContextualizerHeader" Opacity="0.8" />
            <StackPanel x:Name="ContextualizerPanel" Spacing="6" />
        </StackPanel>
    </StackPanel>
</UserControl>
