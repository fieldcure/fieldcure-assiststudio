<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AssistStudio.Controls.McpServerCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Padding="16,12" CornerRadius="6" BorderThickness="1"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
        <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: Server info -->
            <StackPanel Grid.Column="0" Spacing="4">
                <!-- Name row: status dot + name + transport badge -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon x:Name="StatusIcon" Glyph="&#xF136;" FontSize="10"
                              VerticalAlignment="Center" />
                    <TextBlock x:Name="ServerNameText"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="4" Padding="6,2,6,2">
                        <TextBlock x:Name="TransportText" FontSize="11" Opacity="0.7" />
                    </Border>
                    <Border x:Name="BuiltInBadge"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="4" Padding="6,2,6,2"
                            Visibility="Collapsed">
                        <TextBlock x:Name="BuiltInText" FontSize="11" Opacity="0.7" />
                    </Border>
                </StackPanel>

                <!-- Detail: command/url + tool count + error -->
                <TextBlock x:Name="DetailText"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Opacity="0.6"
                           TextWrapping="Wrap"
                           MaxWidth="500" />

                <!-- Version -->
                <TextBlock x:Name="VersionText"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Opacity="0.45"
                           FontSize="11"
                           Visibility="Collapsed" />
            </StackPanel>

            <!-- Right: Actions (2 rows) -->
            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                <ToggleSwitch x:Name="EnableToggle"
                              OnContent="" OffContent="" MinWidth="0"
                              HorizontalAlignment="Right"
                              Toggled="EnableToggle_Toggled" />
                <StackPanel Orientation="Horizontal" Spacing="4"
                            HorizontalAlignment="Right">
                    <Button x:Name="EditButton"
                            x:Uid="McpCard_Edit"
                            Style="{ThemeResource SubtleButtonStyle}"
                            Padding="6" Click="EditButton_Click">
                        <FontIcon Glyph="&#xE70F;" FontSize="14" />
                    </Button>
                    <Button x:Name="ReconnectButton"
                            x:Uid="McpCard_Reconnect"
                            Style="{ThemeResource SubtleButtonStyle}"
                            Padding="6" Click="ReconnectButton_Click">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    </Button>
                    <Button x:Name="DeleteButton"
                            x:Uid="McpCard_Delete"
                            Style="{ThemeResource SubtleButtonStyle}"
                            Padding="6" Click="DeleteButton_Click">
                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Optional bottom content slot (e.g., CollapsibleSection for built-in server settings) -->
        <ContentPresenter
            x:Name="BottomContentPresenter"
            Content="{x:Bind BottomContent, Mode=OneWay}"
            Visibility="Collapsed"
            Margin="0,8,0,0" />
        </StackPanel>
    </Border>
</UserControl>
