<?xml version="1.0" encoding="utf-8"?>
<local:ThemedContentDialog
    x:Class="AssistStudio.Controls.Dialogs.KbEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AssistStudio.Controls.Dialogs"
    xmlns:controls="using:AssistStudio.Controls"
    DefaultButton="Primary">

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600" Width="400" Margin="8">
        <StackPanel Spacing="{StaticResource CompactSpacing}" Padding="0,0,0,24">
            <!-- Source Folders -->
            <StackPanel Spacing="4">
                <TextBlock
                    x:Name="FoldersHeader"
                    x:Uid="KbEditDialog_FoldersHeader"
                    Style="{StaticResource ControlHeaderStyle}"/>
                <ItemsControl x:Name="FolderList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:FolderRowViewModel">
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Text="{x:Bind Path}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center"/>
                                <Button
                                    Grid.Column="1"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    AutomationProperties.AutomationId="KbFolderRemoveButton"
                                    AutomationProperties.Name="{x:Bind RemoveTooltip}"
                                    Click="OnRemoveFolderClicked">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind RemoveTooltip}" Placement="Mouse" />
                                    </ToolTipService.ToolTip>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button
                    x:Name="AddFolderButton"
                    x:Uid="KbEditDialog_AddFolderButton"
                    Click="OnAddFolderClicked"/>
                <TextBlock
                    x:Name="FolderWarning"
                    Style="{StaticResource DescriptionTextBlockStyle}"
                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                    TextWrapping="Wrap"
                    Visibility="Collapsed"/>
            </StackPanel>

            <!-- Name -->
            <TextBox
                x:Name="NameBox"
                x:Uid="KbEditDialog_NameBox"
                TextChanged="OnNameTextChanged"/>
            <TextBlock
                x:Name="NameHint"
                x:Uid="KbEditDialog_NameHint"
                Style="{StaticResource DescriptionTextBlockStyle}"
                Opacity="0.5"/>

            <!-- Model Selection -->
            <controls:EmbeddingModelSelector x:Name="ModelSelector"/>

            <!-- Indexing Timing -->
            <RadioButtons
                x:Name="TimingRadios"
                x:Uid="KbEditDialog_TimingRadios"
                Margin="0,0,0,0"
                SelectionChanged="OnTimingSelectionChanged">
                <RadioButton x:Name="TimingNowRadio" x:Uid="KbEditDialog_TimingNowRadio"/>
                <RadioButton x:Name="TimingOnCloseRadio" x:Uid="KbEditDialog_TimingOnCloseRadio"/>
            </RadioButtons>
            <TextBlock
                x:Name="TimingHint"
                x:Uid="KbEditDialog_TimingHint"
                Style="{StaticResource DescriptionTextBlockStyle}"
                Opacity="0.6"
                TextWrapping="Wrap"
                Visibility="Collapsed"/>

            <!-- Re-index warning (Edit mode only) -->
            <TextBlock
                x:Name="ReindexWarning"
                x:Uid="KbEditDialog_ReindexWarning"
                Style="{StaticResource DescriptionTextBlockStyle}"
                Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"                       
                TextWrapping="Wrap"
                Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</local:ThemedContentDialog>
