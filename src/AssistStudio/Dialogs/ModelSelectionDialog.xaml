<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="AssistStudio.Dialogs.ModelSelectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="ModelDialog"
    Title="Ollama Models"
    CloseButtonText="Close"
    DefaultButton="Close">

    <StackPanel Spacing="16" MinWidth="500">
        <!-- Hardware Info -->
        <StackPanel x:Name="HardwarePanel" Spacing="2" Opacity="0.7">
            <TextBlock x:Name="GpuInfoText" FontSize="12" />
            <TextBlock x:Name="RamInfoText" FontSize="12" />
        </StackPanel>

        <!-- Local Models -->
        <TextBlock x:Uid="ModelDialog_LocalModels" Text="Local Models"
                   Style="{StaticResource SubtitleTextBlockStyle}" />
        <TextBlock x:Name="NoLocalModelsText" x:Uid="ModelDialog_NoLocalModels"
                   Text="No models downloaded yet."
                   FontSize="12" Opacity="0.6" Visibility="Collapsed" />
        <ListView x:Name="LocalModelsList"
                  MaxHeight="200"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Size}" VerticalAlignment="Center" Opacity="0.6" />
                        <Button Grid.Column="2" x:Uid="ModelDialog_Delete"
                                Content="Delete" Tag="{Binding Name}"
                                Click="OnDeleteModel" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Available Models -->
        <TextBlock x:Uid="ModelDialog_AvailableModels" Text="Available Models"
                   Style="{StaticResource SubtitleTextBlockStyle}" />
        <ListView x:Name="AvailableModelsList"
                  MaxHeight="200"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding CompatIcon}" VerticalAlignment="Center"
                                   FontSize="14" />
                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" />
                            <TextBlock Text="{Binding CompatText}" FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding EstimatedSize}" VerticalAlignment="Center"
                                   Opacity="0.6" FontSize="12" />
                        <Button Grid.Column="3" x:Uid="ModelDialog_Pull"
                                Content="Download" Tag="{Binding Name}"
                                Click="OnPullModel" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Custom Pull -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="CustomModelBox"
                     x:Uid="ModelDialog_CustomModel"
                     PlaceholderText="Custom model name" Width="330" />
            <Button x:Uid="ModelDialog_PullCustom" Content="Download" Click="OnPullCustomModel" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
