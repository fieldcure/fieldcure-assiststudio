<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AssistStudio.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AssistStudio">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="StatusErrorForegroundBrush" Color="#C42B1C" />
                    <SolidColorBrush x:Key="StatusAccentForegroundBrush" Color="#005A9E" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="StatusErrorForegroundBrush" Color="#FC7856" />
                    <SolidColorBrush x:Key="StatusAccentForegroundBrush" Color="#4CC2FF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
