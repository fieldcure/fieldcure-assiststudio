<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AssistStudio.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AssistStudio"
    xmlns:converters="using:AssistStudio.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Controls/Shimmer/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- SubtleButtonStyle is built-in since WinAppSDK 1.8 (XamlControlsResources) -->

            <!--  Converters  -->
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" IsInverted="True" />

            <!--  Style Overrides  -->
            <!--
                Standalone header for sections whose siblings use TextBox / ComboBox /
                ToggleSwitch Header properties. Matches the default ContentPresenter
                used by those controls' Header (FontWeight=Normal, primary text color,
                14px) so mixed section labels align visually without touching control
                HeaderTemplates.
            -->
            <Style x:Key="ControlHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Foreground" Value="{ThemeResource TextControlHeaderForeground}" />
            </Style>
            <Style x:Key="CompactSubtitleTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource SubtitleTextBlockStyle}">
                <Setter Property="FontSize" Value="18" />
            </Style>
            <Style x:Key="DescriptionTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
                <Setter Property="Foreground" Value="{ThemeResource SystemBaseMediumHighColor}" />
            </Style>
            <Style x:Key="PageTitleTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource TitleTextBlockStyle}">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="VerticalAlignment" Value="Bottom" />
                <Setter Property="Padding" Value="0,0,0,10" />
            </Style>
            <Style x:Key="EmptyStateTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
                <Setter Property="TextAlignment" Value="Center" />
            </Style>
            <Style x:Key="RowHeaderTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>
            
            <!--
                Tab context menu presenter — the default border clashes visually with
                the tab-strip chrome. Assigned to TabContextFlyout.MenuFlyoutPresenterStyle
                from code in TabContextFlyout.cs.
            -->
            <Style x:Key="TabContextMenuFlyoutPresenterStyle" TargetType="MenuFlyoutPresenter">
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <!--  ComboBox separator (non-interactive divider line)  -->
            <Style x:Key="ComboBoxSeparatorItemStyle" TargetType="ComboBoxItem">
                <Setter Property="IsEnabled" Value="False" />
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Height" Value="9" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border
                                Height="1"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--  Standard Spacing Values  -->
            <x:Double x:Key="SectionContentSpacing">20</x:Double>
            <x:Double x:Key="SectionGroupSpacing">24</x:Double>

            <!--  Other standard spacings for consistency  -->
            <x:Double x:Key="StandardSpacing">16</x:Double>
            <x:Double x:Key="CompactSpacing">12</x:Double>
            <x:Double x:Key="TightSpacing">8</x:Double>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="StatusErrorForegroundBrush" Color="#C42B1C" />
                    <SolidColorBrush x:Key="StatusAccentForegroundBrush" Color="#005A9E" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="StatusErrorForegroundBrush" Color="#FC7856" />
                    <SolidColorBrush x:Key="StatusAccentForegroundBrush" Color="#4CC2FF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
