<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.ConnectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20" BorderThickness="0,0,0,1"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <TextBlock x:Uid="Connect_Title" Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16" Padding="20" MaxWidth="700" HorizontalAlignment="Left">

                <!-- Description -->
                <TextBlock x:Uid="Connect_Description"
                           Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7"
                           TextWrapping="Wrap" />

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="AddServerButton" Click="AddServerButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock x:Name="AddServerText" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ImportButton" Click="ImportButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8B5;" FontSize="14" />
                            <TextBlock x:Name="ImportText" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Server list -->
                <StackPanel x:Name="ServerListPanel" Spacing="8" />

                <!-- Empty state -->
                <TextBlock x:Name="EmptyStateText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.5"
                           Visibility="Visible" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
