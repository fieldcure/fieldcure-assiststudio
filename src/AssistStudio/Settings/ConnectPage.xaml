<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.ConnectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:AssistStudio.Controls"
    xmlns:mcp="using:AssistStudio.Mcp"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20" BorderThickness="0,0,0,1"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <TextBlock x:Uid="Connect_Title" Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16" Padding="20,20,20,44" MaxWidth="700" HorizontalAlignment="Left">

                <!-- Description -->
                <TextBlock x:Uid="Connect_Description"
                           Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7"
                           TextWrapping="Wrap" />

                <!-- Built-in servers (grouped, tight spacing) -->
                <StackPanel Spacing="8">

                <!-- 1. Workspace Folders (Filesystem) — info-only placeholder -->
                <controls:McpServerCard x:Name="FilesystemCard" />

                <!-- 2. Knowledge Archive (RAG) — inline card with folder/reindex -->
                <Border x:Name="KnowledgeArchiveCard"
                        Padding="16,12" CornerRadius="6" BorderThickness="1"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: Info -->
                        <StackPanel Grid.Column="0" Spacing="4">
                            <!-- Title row -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:Name="RagStatusIcon" Glyph="&#xF136;" FontSize="10"
                                          VerticalAlignment="Center" />
                                <TextBlock x:Name="RagTitleText" Text="Knowledge Archive"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           VerticalAlignment="Center" />
                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        CornerRadius="4" Padding="6,2,6,2">
                                    <TextBlock Text="Stdio" FontSize="11" Opacity="0.7" />
                                </Border>
                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        CornerRadius="4" Padding="6,2,6,2">
                                    <TextBlock x:Name="RagBuiltInText" FontSize="11" Opacity="0.7" />
                                </Border>
                            </StackPanel>

                            <!-- Detail / status text -->
                            <TextBlock x:Name="RagDetailText"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.6" TextWrapping="Wrap" MaxWidth="500" />

                            <!-- Warning: embedding not configured -->
                            <StackPanel x:Name="RagWarningPanel" Orientation="Horizontal" Spacing="4"
                                        Visibility="Collapsed">
                                <FontIcon Glyph="&#xE7BA;" FontSize="12"
                                          Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                                          VerticalAlignment="Center" />
                                <TextBlock x:Name="RagWarningText"
                                           Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Add folder button -->
                            <Button x:Name="RagAddFolderButton"
                                    Click="OnAddArchiveFolder"
                                    Style="{ThemeResource SubtleButtonStyle}"
                                    Padding="8,4" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE710;" FontSize="12" />
                                    <TextBlock x:Name="RagAddFolderText" Text="Add Archive Folder" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Right: Actions (bottom-aligned to match user server cards) -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal" Spacing="4"
                                        HorizontalAlignment="Right">
                                <Button x:Name="RagReindexButton"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Padding="6" Click="OnRagReindex"
                                        Visibility="Collapsed">
                                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                </Button>
                                <Button x:Name="RagSettingsButton"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Padding="6" Click="OnNavigateToAppTasks">
                                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                </StackPanel> <!-- end built-in servers -->

                <!-- Action buttons (user-configured servers) -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="AddServerButton" Click="AddServerButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock x:Name="AddServerText" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ImportButton" Click="ImportButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8B5;" FontSize="14" />
                            <TextBlock x:Name="ImportText" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- User-configured server list -->
                <ItemsControl x:Name="ServerListControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="mcp:McpServerConnection">
                            <controls:McpServerCard Connection="{x:Bind}"
                                                    Margin="0,0,0,8"
                                                    EnableToggled="OnCardEnableToggled"
                                                    EditRequested="OnCardEditRequested"
                                                    ReconnectRequested="OnCardReconnectRequested"
                                                    DeleteRequested="OnCardDeleteRequested" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock x:Name="EmptyStateText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.5"
                           Visibility="Visible" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
