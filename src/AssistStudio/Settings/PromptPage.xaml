<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.PromptPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:AssistStudio.Settings"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Page.Resources>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="Prompt_Title" Text="System Prompt"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20,16">
            <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                <TextBlock x:Uid="Prompt_Description" Text="Configure the system prompt sent to AI models."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.7" />

                <!-- Preset list -->
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="Prompt_Presets" Text="Presets"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="AddPresetButton" Grid.Column="1"
                                x:Uid="Prompt_AddPreset"
                                Click="OnAddPresetClicked"
                                ToolTipService.ToolTip="Add preset"
                                Padding="6">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                        </Button>
                    </Grid>

                    <ListView x:Name="PresetListView"
                              SelectionMode="Single"
                              SelectionChanged="OnPresetSelectionChanged"
                              MaxHeight="200">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Padding="4"
                                            x:Uid="Prompt_DeletePreset"
                                            Visibility="{Binding IsBuiltIn, Converter={StaticResource InverseBoolToVisibility}}"
                                            Click="OnDeletePresetClicked"
                                            ToolTipService.ToolTip="Delete"
                                            Style="{StaticResource SubtleButtonStyle}">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Editor -->
                <StackPanel Spacing="8">
                    <TextBox x:Name="PresetNameBox"
                             x:Uid="Prompt_PresetName"
                             Header="Name"
                             PlaceholderText="Preset name"
                             TextChanged="OnEditorChanged" />
                    <TextBox x:Name="SystemPromptBox"
                             x:Uid="Prompt_Placeholder"
                             Header="System Prompt"
                             PlaceholderText="Enter system prompt..."
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="200"
                             TextChanged="OnEditorChanged" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
