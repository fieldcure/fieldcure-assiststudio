<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.PersonalizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="Personalization_Title" Text="Personalization"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20,16">
            <StackPanel Spacing="16">

                <TextBlock x:Uid="Personalization_Theme" Text="Theme"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <RadioButtons x:Name="ThemeRadioButtons"
                              SelectionChanged="OnThemeChanged">
                    <RadioButton x:Uid="Personalization_System" Content="System" Tag="System" />
                    <RadioButton x:Uid="Personalization_Light" Content="Light" Tag="Light" />
                    <RadioButton x:Uid="Personalization_Dark" Content="Dark" Tag="Dark" />
                </RadioButtons>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
