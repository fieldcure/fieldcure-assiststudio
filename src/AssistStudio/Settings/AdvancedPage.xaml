<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.AdvancedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="Advanced_Title" Text="Advanced"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20,16">
            <StackPanel Spacing="16">

                <!-- Language -->
                <TextBlock x:Uid="Advanced_Language" Text="Language"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <TextBlock x:Uid="Advanced_LanguageDescription"
                           Text="Override the system default language. Changes take effect after restarting the app."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.7" />

                <ComboBox x:Name="LanguagePicker"
                          Width="220"
                          SelectionChanged="OnLanguageChanged" />

                <InfoBar x:Name="LanguageRestartInfo"
                         x:Uid="Advanced_Restart"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Warning"
                         Title="Restart required"
                         Message="Please restart the app to apply the language change." />

                <!-- Logging -->
                <TextBlock x:Uid="Advanced_Logging" Text="Logging"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="0,16,0,0" />

                <TextBlock x:Uid="Advanced_LoggingDescription"
                           Text="Application logs are stored locally for troubleshooting."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.7" />

                <Button x:Uid="Advanced_OpenLogsFolder"
                        Content="Open logs folder"
                        Click="OnOpenLogsFolderClick">
                    <Button.Resources>
                        <FontIcon x:Key="ButtonIcon" Glyph="&#xE838;" FontSize="14" />
                    </Button.Resources>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
