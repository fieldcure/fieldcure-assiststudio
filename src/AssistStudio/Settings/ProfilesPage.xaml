<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:AssistStudio.Settings"
    xmlns:models="using:FieldCure.AssistStudio.Models"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Page.Resources>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="Profiles_Title" Text="Profiles"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20,16">
            <StackPanel Spacing="16" Padding="0,0,0,24">

                <TextBlock x:Uid="Profiles_Description" Text="Create profiles with different instructions, model preferences, and tool permissions."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.7" />

                <!-- Profile list -->
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="Profiles_List" Text="Profiles"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="AddProfileButton" Grid.Column="1"
                                x:Uid="Profiles_AddProfile"
                                Click="OnAddProfileClicked"
                                ToolTipService.ToolTip="Add profile"
                                Padding="6">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                        </Button>
                    </Grid>

                    <ListView x:Name="ProfileListView"
                              SelectionMode="Single"
                              SelectionChanged="OnProfileSelectionChanged"
                              MaxHeight="200">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Profile">
                                <Grid Padding="4,2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Padding="4"
                                            x:Uid="Profiles_DeleteProfile"
                                            Visibility="{x:Bind IsBuiltIn, Converter={StaticResource InverseBoolToVisibility}}"
                                            Click="OnDeleteProfileClicked"
                                            ToolTipService.ToolTip="Delete"
                                            Style="{StaticResource SubtleButtonStyle}">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Editor -->
                <StackPanel Spacing="8">
                    <TextBox x:Name="ProfileNameBox"
                             x:Uid="Profiles_ProfileName"
                             Header="Name"
                             PlaceholderText="Profile name"
                             TextChanged="OnEditorChanged" />
                    <TextBox x:Name="SystemPromptBox"
                             x:Uid="Profiles_Instructions"
                             Header="Instructions"
                             PlaceholderText="Enter instructions..."
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="200"
                             TextChanged="OnEditorChanged" />

                    <!-- Desired Provider -->
                    <TextBlock x:Uid="Profiles_DesiredProvider" Text="Desired provider"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ComboBox x:Name="ProviderCombo"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="OnProviderChanged" />

                    <!-- Desired Model -->
                    <TextBlock x:Uid="Profiles_DesiredModel" Text="Desired model"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ComboBox x:Name="ModelCombo"
                              HorizontalAlignment="Stretch"
                              IsEnabled="False"
                              SelectionChanged="OnModelChanged" />

                    <!-- Desired Tools -->
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Profiles_DesiredTools" Text="Desired tools"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Uid="Profiles_ToolsWarning"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                   TextWrapping="Wrap" />
                        <StackPanel x:Name="ToolsPanel" Spacing="4" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
