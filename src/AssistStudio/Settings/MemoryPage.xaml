<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.MemoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="Memory_Title" Text="Memory"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20,16">
            <StackPanel Spacing="12" Padding="0,0,0,24">

                <!-- Empty state -->
                <TextBlock x:Name="EmptyText" x:Uid="Memory_Empty" Text="No memories saved yet."
                           Visibility="Collapsed"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Opacity="0.6" />

                <!-- Memory list -->
                <ItemsRepeater x:Name="MemoryList" />

                <!-- Footer: counter + Clear All -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="CounterText" Grid.Column="0"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.6"
                               VerticalAlignment="Center" />

                    <Button x:Name="ClearAllButton" Grid.Column="1"
                            x:Uid="Memory_ClearAll" Content="Clear All"
                            Click="OnClearAllClicked" />
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
