<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.ModelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AssistStudio.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="Models_Title" Text="Models"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20,20,20,0">
            <StackPanel Spacing="24" Padding="0,0,0,80">

                <!-- ============================== -->
                <!-- Cloud Inference (SaaS) Section -->
                <!-- ============================== -->
                <TextBlock x:Uid="Models_CloudSection" Text="Cloud models"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock x:Uid="Models_ApiKeyStorageInfo"
                           Text="API keys are encrypted and stored securely on this device."
                           FontSize="12" Opacity="0.6"
                           TextWrapping="Wrap" Margin="0,-16,0,0" />

                <!-- Anthropic Claude -->
                <controls:CollapsibleSection x:Name="ClaudeSection"
                                              Header="Anthropic Claude"
                                              IsExpanded="False">
                    <controls:CollapsibleSection.Body>
                        <StackPanel Spacing="8">
                            <!-- Input state (no key) -->
                            <Grid x:Name="ClaudeKeyInputPanel" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="ClaudeApiKeyBox"
                                             x:Uid="Models_ApiKeyBox"
                                             PlaceholderText="API Key" />
                                <Button Grid.Column="1"
                                        x:Uid="Models_AddKeyButton"
                                        Content="Add"
                                        Click="OnAddClaudeKey" />
                            </Grid>
                            <!-- Display state (key exists) -->
                            <Grid x:Name="ClaudeKeyDisplayPanel" Visibility="Collapsed" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ClaudeMaskedKeyText"
                                           VerticalAlignment="Center" Opacity="0.7"
                                           IsTextSelectionEnabled="True" />
                                <Button Grid.Column="1"
                                        x:Uid="Models_RemoveKey"
                                        ToolTipService.ToolTip="Remove Key" ToolTipService.Placement="Mouse"
                                        Click="OnRemoveClaudeKey" Padding="6,4">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                              Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                            <StackPanel x:Name="ClaudeOptionsPanel" Spacing="8" Visibility="Collapsed">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="Models_DefaultModel" Text="Default model" FontSize="12" Opacity="0.7" />
                                    <ComboBox x:Name="ClaudeModelCombo"
                                              x:Uid="Models_ModelNotAvailable"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              PlaceholderText="Not available"
                                              SelectionChanged="OnCloudModelChanged" />
                                </StackPanel>
                                <NumberBox x:Name="ClaudeMaxTokensBox"
                                           x:Uid="Models_MaxTokens"
                                           Header="Max tokens"
                                           Value="4096" Minimum="1" Maximum="1000000"
                                           SpinButtonPlacementMode="Inline"
                                           SmallChange="1024" LargeChange="4096"
                                           ValueChanged="OnMaxTokensChanged" />
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="Models_PdfHandling" Text="PDF handling" FontSize="12" Opacity="0.7" />
                                    <ComboBox x:Name="ClaudePdfCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnPdfHandlingChanged" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <ComboBox x:Name="ClaudeThinkingOverrideCombo"
                                              x:Uid="Models_ThinkingOverride"
                                              Header="Reasoning mode"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnThinkingOverrideChanged" />
                                    <ToggleSwitch x:Name="ClaudeThinkingToggle"
                                                  x:Uid="Models_ExtendedThinking"
                                                  Header="Extended reasoning"
                                                  Toggled="OnThinkingToggled" />
                                    <NumberBox x:Name="ClaudeThinkingBudget"
                                               x:Uid="Models_ThinkingBudget"
                                               Header="Reasoning budget (tokens)"
                                               Value="4096" Minimum="1024" Maximum="128000"
                                               SpinButtonPlacementMode="Inline"
                                               SmallChange="1024" LargeChange="4096"
                                               IsEnabled="False"
                                               ValueChanged="OnThinkingBudgetChanged" />
                                    <TextBlock x:Name="ClaudeThinkingHint"
                                               FontSize="12" Opacity="0.6"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </controls:CollapsibleSection.Body>
                </controls:CollapsibleSection>

                <!-- OpenAI -->
                <controls:CollapsibleSection x:Name="OpenAISection"
                                              Header="OpenAI"
                                              IsExpanded="False">
                    <controls:CollapsibleSection.Body>
                        <StackPanel Spacing="8">
                            <Grid x:Name="OpenAIKeyInputPanel" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="OpenAIApiKeyBox"
                                             PlaceholderText="API Key" />
                                <Button Grid.Column="1"
                                        x:Uid="Models_AddKeyButton"
                                        Content="Add"
                                        Click="OnAddOpenAIKey" />
                            </Grid>
                            <Grid x:Name="OpenAIKeyDisplayPanel" Visibility="Collapsed" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="OpenAIMaskedKeyText"
                                           VerticalAlignment="Center" Opacity="0.7"
                                           IsTextSelectionEnabled="True" />
                                <Button Grid.Column="1"
                                        x:Uid="Models_RemoveKey"
                                        ToolTipService.ToolTip="Remove Key" ToolTipService.Placement="Mouse"
                                        Click="OnRemoveOpenAIKey" Padding="6,4">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                              Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                            <StackPanel x:Name="OpenAIOptionsPanel" Spacing="8" Visibility="Collapsed">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="Models_DefaultModel" Text="Default model" FontSize="12" Opacity="0.7" />
                                    <ComboBox x:Name="OpenAIModelCombo"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              PlaceholderText="Not available"
                                              SelectionChanged="OnCloudModelChanged" />
                                </StackPanel>
                                <NumberBox x:Name="OpenAIMaxTokensBox"
                                           x:Uid="Models_MaxTokens"
                                           Header="Max tokens"
                                           Value="4096" Minimum="1" Maximum="1000000"
                                           SpinButtonPlacementMode="Inline"
                                           SmallChange="1024" LargeChange="4096"
                                           ValueChanged="OnMaxTokensChanged" />
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="Models_PdfHandling" Text="PDF handling" FontSize="12" Opacity="0.7" />
                                    <ComboBox x:Name="OpenAIPdfCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnPdfHandlingChanged" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <ComboBox x:Name="OpenAIThinkingOverrideCombo"
                                              x:Uid="Models_ThinkingOverride"
                                              Header="Reasoning mode"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnThinkingOverrideChanged" />
                                    <ToggleSwitch x:Name="OpenAIThinkingToggle"
                                                  x:Uid="Models_ExtendedThinking"
                                                  Header="Extended reasoning"
                                                  Toggled="OnThinkingToggled" />
                                    <NumberBox x:Name="OpenAIThinkingBudget"
                                               x:Uid="Models_ThinkingBudget"
                                               Header="Reasoning budget (tokens)"
                                               Value="4096" Minimum="1024" Maximum="128000"
                                               SpinButtonPlacementMode="Inline"
                                               SmallChange="1024" LargeChange="4096"
                                               IsEnabled="False"
                                               ValueChanged="OnThinkingBudgetChanged" />
                                    <TextBlock x:Name="OpenAIThinkingHint"
                                               FontSize="12" Opacity="0.6"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </controls:CollapsibleSection.Body>
                </controls:CollapsibleSection>

                <!-- Google Gemini -->
                <controls:CollapsibleSection x:Name="GeminiSection"
                                              Header="Google Gemini"
                                              IsExpanded="False">
                    <controls:CollapsibleSection.Body>
                        <StackPanel Spacing="8">
                            <Grid x:Name="GeminiKeyInputPanel" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="GeminiApiKeyBox"
                                             PlaceholderText="API Key" />
                                <Button Grid.Column="1"
                                        x:Uid="Models_AddKeyButton"
                                        Content="Add"
                                        Click="OnAddGeminiKey" />
                            </Grid>
                            <Grid x:Name="GeminiKeyDisplayPanel" Visibility="Collapsed" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="GeminiMaskedKeyText"
                                           VerticalAlignment="Center" Opacity="0.7"
                                           IsTextSelectionEnabled="True" />
                                <Button Grid.Column="1"
                                        x:Uid="Models_RemoveKey"
                                        ToolTipService.ToolTip="Remove Key" ToolTipService.Placement="Mouse"
                                        Click="OnRemoveGeminiKey" Padding="6,4">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                              Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                            <StackPanel x:Name="GeminiOptionsPanel" Spacing="8" Visibility="Collapsed">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="Models_DefaultModel" Text="Default model" FontSize="12" Opacity="0.7" />
                                    <ComboBox x:Name="GeminiModelCombo"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              PlaceholderText="Not available"
                                              SelectionChanged="OnCloudModelChanged" />
                                </StackPanel>
                                <NumberBox x:Name="GeminiMaxTokensBox"
                                           x:Uid="Models_MaxTokens"
                                           Header="Max tokens"
                                           Value="4096" Minimum="1" Maximum="1000000"
                                           SpinButtonPlacementMode="Inline"
                                           SmallChange="1024" LargeChange="4096"
                                           ValueChanged="OnMaxTokensChanged" />
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="Models_PdfHandling" Text="PDF handling" FontSize="12" Opacity="0.7" />
                                    <ComboBox x:Name="GeminiPdfCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnPdfHandlingChanged" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <ComboBox x:Name="GeminiThinkingOverrideCombo"
                                              x:Uid="Models_ThinkingOverride"
                                              Header="Reasoning mode"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnThinkingOverrideChanged" />
                                    <ToggleSwitch x:Name="GeminiThinkingToggle"
                                                  x:Uid="Models_ExtendedThinking"
                                                  Header="Extended reasoning"
                                                  Toggled="OnThinkingToggled" />
                                    <NumberBox x:Name="GeminiThinkingBudget"
                                               x:Uid="Models_ThinkingBudget"
                                               Header="Reasoning budget (tokens)"
                                               Value="4096" Minimum="1024" Maximum="128000"
                                               SpinButtonPlacementMode="Inline"
                                               SmallChange="1024" LargeChange="4096"
                                               IsEnabled="False"
                                               ValueChanged="OnThinkingBudgetChanged" />
                                    <TextBlock x:Name="GeminiThinkingHint"
                                               FontSize="12" Opacity="0.6"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </controls:CollapsibleSection.Body>
                </controls:CollapsibleSection>

                <!-- Groq -->
                <controls:CollapsibleSection x:Name="GroqSection"
                                              Header="Groq"
                                              IsExpanded="False">
                    <controls:CollapsibleSection.Body>
                        <StackPanel Spacing="8">
                            <Grid x:Name="GroqKeyInputPanel" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="GroqApiKeyBox"
                                             PlaceholderText="API Key" />
                                <Button Grid.Column="1"
                                        x:Uid="Models_AddKeyButton"
                                        Content="Add"
                                        Click="OnAddGroqKey" />
                            </Grid>
                            <Grid x:Name="GroqKeyDisplayPanel" Visibility="Collapsed" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="GroqMaskedKeyText"
                                           VerticalAlignment="Center" Opacity="0.7"
                                           IsTextSelectionEnabled="True" />
                                <Button Grid.Column="1"
                                        x:Uid="Models_RemoveKey"
                                        ToolTipService.ToolTip="Remove Key" ToolTipService.Placement="Mouse"
                                        Click="OnRemoveGroqKey" Padding="6,4">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                              Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                            <StackPanel x:Name="GroqOptionsPanel" Spacing="8" Visibility="Collapsed">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="Models_DefaultModel" Text="Default model" FontSize="12" Opacity="0.7" />
                                    <ComboBox x:Name="GroqModelCombo"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              PlaceholderText="Not available"
                                              SelectionChanged="OnCloudModelChanged" />
                                </StackPanel>
                                <NumberBox x:Name="GroqMaxTokensBox"
                                           x:Uid="Models_MaxTokens"
                                           Header="Max tokens"
                                           Value="4096" Minimum="1" Maximum="1000000"
                                           SpinButtonPlacementMode="Inline"
                                           SmallChange="1024" LargeChange="4096"
                                           ValueChanged="OnMaxTokensChanged" />
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="Models_PdfHandling" Text="PDF handling" FontSize="12" Opacity="0.7" />
                                    <ComboBox x:Name="GroqPdfCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnPdfHandlingChanged" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <ComboBox x:Name="GroqThinkingOverrideCombo"
                                              x:Uid="Models_ThinkingOverride"
                                              Header="Reasoning mode"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnThinkingOverrideChanged" />
                                    <ToggleSwitch x:Name="GroqThinkingToggle"
                                                  x:Uid="Models_ExtendedThinking"
                                                  Header="Extended reasoning"
                                                  Toggled="OnThinkingToggled" />
                                    <NumberBox x:Name="GroqThinkingBudget"
                                               x:Uid="Models_ThinkingBudget"
                                               Header="Reasoning budget (tokens)"
                                               Value="4096" Minimum="1024" Maximum="128000"
                                               SpinButtonPlacementMode="Inline"
                                               SmallChange="1024" LargeChange="4096"
                                               IsEnabled="False"
                                               ValueChanged="OnThinkingBudgetChanged" />
                                    <TextBlock x:Name="GroqThinkingHint"
                                               FontSize="12" Opacity="0.6"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </controls:CollapsibleSection.Body>
                </controls:CollapsibleSection>

                <!-- ============================== -->
                <!-- Local Inference (On-Device)    -->
                <!-- ============================== -->
                <Rectangle Height="2" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

                <TextBlock x:Uid="Models_LocalSection" Text="Local models"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <!-- Ollama -->
                <controls:CollapsibleSection x:Name="OllamaSection"
                                              Header="Ollama"
                                              IsExpanded="False">
                    <controls:CollapsibleSection.Body>
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock x:Name="OllamaStatusText"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <ProgressRing x:Name="OllamaSpinner" IsActive="False"
                                              Width="16" Height="16" Visibility="Collapsed" />
                                <Button x:Name="OllamaRefreshButton"
                                        Padding="4"
                                        x:Uid="Models_RefreshStatus"
                                        ToolTipService.ToolTip="Check status" ToolTipService.Placement="Mouse"
                                        Click="OnCheckOllama">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                              Glyph="&#xE72C;" FontSize="12" />
                                </Button>
                            </StackPanel>

                            <!-- Server URL -->
                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="Models_OllamaServerUrl"
                                           Text="Server URL" FontSize="12" Opacity="0.7" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="OllamaUrlBox"
                                             PlaceholderText="http://localhost:11434"
                                             LostFocus="OnOllamaUrlChanged">
                                        <TextBox.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem x:Uid="Models_OllamaLocalhost"
                                                                Text="Reset to localhost"
                                                                Click="OnOllamaLocalhost">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE10F;" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </TextBox.ContextFlyout>
                                    </TextBox>
                                    <Button x:Name="OllamaTestButton"
                                            Grid.Column="1"
                                            x:Uid="Models_OllamaTestConnection"
                                            Content="Test" Click="OnTestOllamaUrl" />
                                </Grid>
                            </StackPanel>

                            <!-- Install guidance -->
                            <StackPanel x:Name="OllamaInstallPanel" Visibility="Collapsed" Spacing="2">
                                <HyperlinkButton x:Uid="Models_DownloadOllama"
                                                 Content="Download Ollama"
                                                 NavigateUri="https://ollama.com/download"
                                                 Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                 Padding="0" />
                            </StackPanel>

                            <!-- Start button -->
                            <Button x:Name="StartOllamaButton"
                                    x:Uid="Models_StartOllama"
                                    Content="Start Ollama" Click="OnStartOllama"
                                    Visibility="Collapsed" />

                            <!-- Browse models -->
                            <Button x:Name="BrowseModelsButton"
                                    x:Uid="Models_BrowsePullModels"
                                    Content="Browse models" Click="OnBrowseOllamaModels"
                                    Visibility="Collapsed" />

                            <!-- Download Progress -->
                            <StackPanel x:Name="PullProgressPanel" Visibility="Collapsed" Spacing="4"
                                        Margin="0,0,0,8">
                                <TextBlock x:Name="PullProgressStatus" FontSize="12" />
                                <ProgressBar x:Name="PullProgressBar" Minimum="0" Maximum="100" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="Models_DefaultModel" Text="Default model" FontSize="12" Opacity="0.7" />
                                <ComboBox x:Name="OllamaModelCombo"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          PlaceholderText="Not available"
                                          SelectionChanged="OnOllamaModelChanged" />
                            </StackPanel>
                            <NumberBox x:Name="OllamaMaxTokensBox"
                                       x:Uid="Models_MaxTokens"
                                       Header="Max tokens"
                                       Value="4096" Minimum="1" Maximum="1000000"
                                       SpinButtonPlacementMode="Inline"
                                       SmallChange="1024" LargeChange="4096"
                                       ValueChanged="OnMaxTokensChanged" />
                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="Models_PdfHandling" Text="PDF handling" FontSize="12" Opacity="0.7" />
                                <ComboBox x:Name="OllamaPdfCombo"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="OnPdfHandlingChanged" />
                            </StackPanel>
                        </StackPanel>
                    </controls:CollapsibleSection.Body>
                </controls:CollapsibleSection>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
