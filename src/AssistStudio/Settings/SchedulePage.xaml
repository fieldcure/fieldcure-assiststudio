<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.SchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: title + counter + refresh -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Uid="Schedule_Title" Text="Schedule"
                       Grid.Column="0"
                       Style="{StaticResource TitleTextBlockStyle}" />

            <TextBlock x:Name="CounterText" Grid.Column="2"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.6"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />

            <Button x:Name="RefreshButton" Grid.Column="3"
                    Click="OnRefreshClicked"
                    Style="{StaticResource SubtleButtonStyle}"
                    Padding="8" MinWidth="0" MinHeight="0">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
        </Grid>

        <!-- Search box -->
        <AutoSuggestBox x:Name="SearchBox" Grid.Row="1"
                        x:Uid="Schedule_SearchBox"
                        Margin="20,12,20,0"
                        QueryIcon="Find"
                        QuerySubmitted="OnSearchQuerySubmitted"
                        TextChanged="OnSearchTextChanged" />

        <!-- Content -->
        <ScrollViewer Grid.Row="2" Padding="20,12">
            <StackPanel Spacing="0" Padding="0,0,0,24">

                <!-- Loading state -->
                <StackPanel x:Name="LoadingPanel" Visibility="Collapsed"
                            Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <ProgressRing IsActive="True" Width="16" Height="16" />
                    <TextBlock x:Name="LoadingText" Text="Loading schedules..."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.6"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Schedule list -->
                <ItemsRepeater x:Name="ScheduleList" />

                <!-- Divider before hint -->
                <Rectangle x:Name="HintDivider" Visibility="Collapsed"
                           Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- Hint text -->
                <TextBlock x:Name="HintText" x:Uid="Schedule_Hint"
                           Visibility="Collapsed"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.5"
                           Margin="0,12,0,0" />

                <!-- Empty state -->
                <StackPanel x:Name="EmptyPanel" Visibility="Collapsed" Spacing="4"
                            Margin="0,8,0,0">
                    <TextBlock x:Uid="Schedule_Empty"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.6" />
                    <TextBlock x:Uid="Schedule_EmptyHint"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               TextWrapping="Wrap"
                               Opacity="0.5" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
