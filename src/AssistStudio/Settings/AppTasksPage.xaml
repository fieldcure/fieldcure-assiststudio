<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.AppTasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="AppTasks_Title" Text="App Tasks"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20,16">
            <StackPanel Spacing="24" MaxWidth="480" HorizontalAlignment="Left" Padding="0,0,0,24">

                <TextBlock x:Uid="AppTasks_Description"
                           Text="Choose which model the app uses for background tasks such as title generation and conversation summaries."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.7" />

                <!-- Model Source Selection -->
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="AppTasks_ModelSource" Text="Model source"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <RadioButtons x:Name="ModelSourceRadio"
                                  SelectionChanged="OnModelSourceChanged">
                        <RadioButton x:Uid="AppTasks_UseCurrent" Content="Use the current chat model" Tag="Current" />
                        <RadioButton x:Uid="AppTasks_UseSpecific" Content="Use a specific provider" Tag="Specific" />
                    </RadioButtons>

                    <ComboBox x:Name="PresetCombo"
                              x:Uid="AppTasks_Provider"
                              Header="Provider"
                              HorizontalAlignment="Stretch"
                              Visibility="Collapsed"
                              SelectionChanged="OnPresetSelectionChanged" />
                </StackPanel>

                <!-- Tasks Toggle -->
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="AppTasks_AutoTasks" Text="Automatic tasks"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <ToggleSwitch x:Name="AutoTitleToggle"
                                  x:Uid="AppTasks_AutoTitle"
                                  Header="Generate conversation titles automatically"
                                  OnContent="On" OffContent="Off"
                                  Toggled="OnAutoTitleToggled" />

                    <ToggleSwitch x:Name="AutoSummaryToggle"
                                  x:Uid="AppTasks_AutoSummary"
                                  Header="Summarize long conversations automatically"
                                  OnContent="On" OffContent="Off"
                                  Toggled="OnAutoSummaryToggled" />
                </StackPanel>

                <!-- Embedding Model -->
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="AppTasks_EmbeddingTitle" Text="Embedding"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <TextBlock x:Uid="AppTasks_EmbeddingDescription"
                               Text="Used for Knowledge Archive document indexing and search. Requires an OpenAI-compatible embedding API."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               TextWrapping="Wrap"
                               Opacity="0.7" />

                    <!-- Ollama group -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Ollama" Opacity="0.6"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Margin="0,4,0,2" />
                        <StackPanel x:Name="OllamaGroup" Spacing="0">
                            <RadioButton x:Name="RbNomicV1" Tag="ollama/nomic-embed-text"
                                         GroupName="EmbeddingModel"
                                         Click="OnEmbeddingModelSelected" Padding="8,6,0,0"
                                         MinHeight="0" VerticalContentAlignment="Top">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="nomic-embed-text" />
                                        <FontIcon x:Name="IcoNomicV1" Glyph="&#xE896;" FontSize="12"
                                                  VerticalAlignment="Center" Opacity="0.5" />
                                        <ProgressRing x:Name="SpinNomicV1" IsActive="False"
                                                      Width="14" Height="14" Visibility="Collapsed" />
                                    </StackPanel>
                                    <TextBlock Text="768 dim · 274MB" Opacity="0.5"
                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="RbNomicV2" Tag="ollama/nomic-embed-text-v2-moe"
                                         GroupName="EmbeddingModel"
                                         Click="OnEmbeddingModelSelected" Padding="8,6,0,0"
                                         MinHeight="0" VerticalContentAlignment="Top">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="nomic-embed-text-v2-moe" />
                                        <FontIcon x:Name="IcoNomicV2" Glyph="&#xE896;" FontSize="12"
                                                  VerticalAlignment="Center" Opacity="0.5" />
                                        <ProgressRing x:Name="SpinNomicV2" IsActive="False"
                                                      Width="14" Height="14" Visibility="Collapsed" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="768 dim · 1.9GB" Opacity="0.5"
                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                CornerRadius="4" Padding="6,1,6,1">
                                            <TextBlock x:Uid="Embedding_Multilingual" Text="Multilingual"
                                                       FontSize="11" Opacity="0.7" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="RbBgeM3" Tag="ollama/bge-m3"
                                         GroupName="EmbeddingModel"
                                         Click="OnEmbeddingModelSelected" Padding="8,6,0,0"
                                         MinHeight="0" VerticalContentAlignment="Top">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="bge-m3" />
                                        <FontIcon x:Name="IcoBgeM3" Glyph="&#xE896;" FontSize="12"
                                                  VerticalAlignment="Center" Opacity="0.5" />
                                        <ProgressRing x:Name="SpinBgeM3" IsActive="False"
                                                      Width="14" Height="14" Visibility="Collapsed" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="1024 dim · 1.2GB" Opacity="0.5"
                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                CornerRadius="4" Padding="6,1,6,1">
                                            <TextBlock x:Uid="Embedding_Multilingual" Text="Multilingual"
                                                       FontSize="11" Opacity="0.7" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </StackPanel>

                    <!-- OpenAI group -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="OpenAI" Opacity="0.6"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Margin="0,4,0,2" />
                        <StackPanel x:Name="OpenAiGroup" Spacing="0">
                            <RadioButton x:Name="RbEmbed3Small" Tag="openai/text-embedding-3-small"
                                         GroupName="EmbeddingModel"
                                         Click="OnEmbeddingModelSelected" Padding="8,6,0,0"
                                         MinHeight="0" VerticalContentAlignment="Top">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="text-embedding-3-small" />
                                    <TextBlock Text="1536 dim" Opacity="0.5"
                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="RbEmbed3Large" Tag="openai/text-embedding-3-large"
                                         GroupName="EmbeddingModel"
                                         Click="OnEmbeddingModelSelected" Padding="8,6,0,0"
                                         MinHeight="0" VerticalContentAlignment="Top">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="text-embedding-3-large" />
                                    <TextBlock Text="3072 dim" Opacity="0.5"
                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </StackPanel>

                    <!-- Model change warning -->
                    <InfoBar x:Name="ModelChangeWarning"
                             x:Uid="Embedding_ModelChangeWarning"
                             Severity="Warning"
                             IsOpen="False"
                             IsClosable="True" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
