<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.AppTasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock x:Uid="AppTasks_Title" Text="App Tasks"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20,16">
            <StackPanel Spacing="24" MaxWidth="480" HorizontalAlignment="Left" Padding="0,0,0,24">

                <TextBlock x:Uid="AppTasks_Description"
                           Text="Choose which model the app uses for background tasks such as title generation and conversation summaries."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.7" />

                <!-- Model Source Selection -->
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="AppTasks_ModelSource" Text="Model source"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <RadioButtons x:Name="ModelSourceRadio"
                                  SelectionChanged="OnModelSourceChanged">
                        <RadioButton x:Uid="AppTasks_UseCurrent" Content="Use the current chat model" Tag="Current" />
                        <RadioButton x:Uid="AppTasks_UseSpecific" Content="Use a specific provider" Tag="Specific" />
                    </RadioButtons>

                    <ComboBox x:Name="PresetCombo"
                              x:Uid="AppTasks_Provider"
                              Header="Provider"
                              HorizontalAlignment="Stretch"
                              Visibility="Collapsed"
                              SelectionChanged="OnPresetSelectionChanged" />
                </StackPanel>

                <!-- Tasks Toggle -->
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="AppTasks_AutoTasks" Text="Automatic tasks"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <ToggleSwitch x:Name="AutoTitleToggle"
                                  x:Uid="AppTasks_AutoTitle"
                                  Header="Generate conversation titles automatically"
                                  OnContent="On" OffContent="Off"
                                  Toggled="OnAutoTitleToggled" />

                    <ToggleSwitch x:Name="AutoSummaryToggle"
                                  x:Uid="AppTasks_AutoSummary"
                                  Header="Summarize long conversations automatically"
                                  OnContent="On" OffContent="Off"
                                  Toggled="OnAutoSummaryToggled" />
                </StackPanel>

                <!-- Embedding -->
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="AppTasks_EmbeddingTitle" Text="Embedding"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <TextBlock x:Uid="AppTasks_EmbeddingDescription"
                               Text="Used for Knowledge Archive document indexing and search. Requires an OpenAI-compatible embedding API (Ollama, OpenAI, etc.)"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               TextWrapping="Wrap"
                               Opacity="0.7" />

                    <ComboBox x:Name="EmbeddingPresetCombo"
                              x:Uid="AppTasks_EmbeddingProvider"
                              Header="Embedding provider"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="OnEmbeddingPresetChanged" />

                    <!-- Claude warning -->
                    <TextBlock x:Name="EmbeddingWarningText"
                               Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />

                    <!-- Quick select: Ollama -->
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Ollama" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                            <Button Content="nomic-embed-text" Click="OnQuickSelectOllama"
                                    Tag="nomic-embed-text"
                                    Style="{ThemeResource SubtleButtonStyle}" Padding="8,4" />
                            <Button Content="mxbai-embed-large" Click="OnQuickSelectOllama"
                                    Tag="mxbai-embed-large"
                                    Style="{ThemeResource SubtleButtonStyle}" Padding="8,4" />
                            <Button Content="bge-m3" Click="OnQuickSelectOllama"
                                    Tag="bge-m3"
                                    Style="{ThemeResource SubtleButtonStyle}" Padding="8,4" />
                        </StackPanel>

                        <!-- Quick select: OpenAI -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="OpenAI" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                            <Button Content="text-embedding-3-small" Click="OnQuickSelectOpenAi"
                                    Tag="text-embedding-3-small"
                                    Style="{ThemeResource SubtleButtonStyle}" Padding="8,4" />
                            <Button Content="text-embedding-ada-002" Click="OnQuickSelectOpenAi"
                                    Tag="text-embedding-ada-002"
                                    Style="{ThemeResource SubtleButtonStyle}" Padding="8,4" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Current selection display -->
                    <TextBlock x:Name="EmbeddingStatusText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.5" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
