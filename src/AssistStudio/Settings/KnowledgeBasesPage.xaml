<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AssistStudio.Settings.KnowledgeBasesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: title + counter + Create button -->
        <Grid Grid.Row="0" Padding="20,14,20,14"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Uid="KB_Title" Text="Knowledge Archive"
                       Grid.Column="0"
                       Style="{StaticResource TitleTextBlockStyle}" />

            <TextBlock x:Name="CounterText" Grid.Column="2"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.6"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />

            <Button x:Name="CreateButton" Grid.Column="3"
                    x:Uid="KB_Create" Content="Create"
                    Click="OnCreateClicked" />
        </Grid>

        <!-- Search box -->
        <AutoSuggestBox x:Name="SearchBox" Grid.Row="1"
                        x:Uid="KB_SearchBox"
                        Margin="20,12,20,0"
                        QueryIcon="Find"
                        QuerySubmitted="OnSearchQuerySubmitted"
                        TextChanged="OnSearchTextChanged" />

        <!-- Match summary bar -->
        <TextBlock x:Name="MatchSummaryText"
                   Grid.Row="2"
                   Visibility="Collapsed"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Margin="20,8,20,0"
                   TextTrimming="CharacterEllipsis" />

        <!-- Content -->
        <ScrollViewer Grid.Row="3" Padding="20,12">
            <StackPanel Spacing="0" Padding="0,0,0,24" MaxWidth="700" HorizontalAlignment="Left">

                <!-- KB list (also used for shimmer placeholders during load) -->
                <ItemsRepeater x:Name="KbList" />

                <!-- Divider before hint -->
                <Rectangle x:Name="HintDivider" Visibility="Collapsed"
                           Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- Hint text (shown when entries exist) -->
                <TextBlock x:Name="HintText" x:Uid="KB_FooterHint"
                           Visibility="Collapsed"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.5"
                           Margin="0,12,0,0" />

                <!-- Empty state (shown when no entries) -->
                <StackPanel x:Name="EmptyPanel" Visibility="Collapsed" Spacing="4"
                            Margin="0,8,0,0">
                    <TextBlock x:Uid="KB_Empty"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.6" />
                    <TextBlock x:Uid="KB_EmptyHint"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               TextWrapping="Wrap"
                               Opacity="0.5" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
