<Window
    x:Class="AnthropicSdkSample.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:FieldCure.AssistStudio.Controls"
    Title="Anthropic SDK Sample">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (right padding reserves space for caption buttons) -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="48"
              Padding="16,0,140,0"
              AutomationProperties.AutomationId="AppTitleBar"
              AutomationProperties.Name="Application title bar">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="HamburgerButton"
                Grid.Column="0"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                Padding="6"
                Style="{StaticResource SubtleButtonStyle}"
                ToolTipService.ToolTip="Application menu"
                AutomationProperties.AutomationId="HamburgerMenuButton"
                AutomationProperties.Name="Application menu">
                <FontIcon
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xE700;"
                    FontSize="16" />
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                        <MenuFlyoutItem
                            x:Name="NewChatMenuItem"
                            Text="New Chat"
                            Click="OnNewChatClick"
                            AutomationProperties.AutomationId="NewChatMenuItem"
                            AutomationProperties.Name="Start a new chat">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8F4;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            x:Name="ExportMenuItem"
                            Text="Export"
                            IsEnabled="False"
                            Click="OnExportClick"
                            AutomationProperties.AutomationId="ExportMenuItem"
                            AutomationProperties.Name="Export conversation to Markdown">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xEDE1;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem
                            x:Name="ThemeMenuItem"
                            Text="Switch to dark"
                            Click="OnThemeToggleClick"
                            AutomationProperties.AutomationId="ThemeMenuItem"
                            AutomationProperties.Name="Toggle theme">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE708;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            Text="Reset API Key"
                            Click="OnResetKeyClicked"
                            AutomationProperties.AutomationId="ResetApiKeyMenuItem"
                            AutomationProperties.Name="Reset API key"
                            AutomationProperties.HelpText="Clears the stored Anthropic API key and prompts for a new one">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE72E;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <TextBlock
                x:Name="AppTitleText"
                Grid.Column="1"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                Text="Anthropic SDK Sample"
                Style="{StaticResource CaptionTextBlockStyle}"
                AutomationProperties.AutomationId="AppTitleText"
                AutomationProperties.Name="Application title" />

            <ComboBox
                x:Name="ModelComboBox"
                Grid.Column="3"
                VerticalAlignment="Center"
                BorderThickness="0"
                Background="Transparent"
                SelectionChanged="OnModelSelectionChanged"
                AutomationProperties.AutomationId="ModelSelector"
                AutomationProperties.Name="Claude model"
                AutomationProperties.HelpText="Selects which Claude model handles the conversation" />
        </Grid>

        <TeachingTip
            x:Name="ExportTip"
            Target="{x:Bind HamburgerButton}"
            IsLightDismissEnabled="True"
            AutomationProperties.AutomationId="ExportTip"
            AutomationProperties.Name="Export result notification" />

        <controls:ChatPanel
            x:Name="ChatPanel"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            DisableInternalSendFlow="True"
            ShowTitleBar="False"
            ShowPresetSelector="False"
            ShowProfileSelector="False"
            Theme="System"
            Placeholder="Ask Claude anything..." />
    </Grid>

</Window>
