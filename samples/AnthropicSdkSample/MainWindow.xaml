<Window
    x:Class="AnthropicSdkSample.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:FieldCure.AssistStudio.Controls"
    Title="Anthropic SDK Sample">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (right padding reserves space for caption buttons) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Padding="16,0,140,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Anthropic SDK Sample"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <ComboBox x:Name="ModelComboBox"
                      Grid.Column="2"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      BorderThickness="0"
                      Background="Transparent"
                      SelectionChanged="OnModelSelectionChanged" />

            <Button Grid.Column="3"
                    Content="Reset API Key"
                    VerticalAlignment="Center"
                    Click="OnResetKeyClicked"
                    Style="{StaticResource DefaultButtonStyle}" />
        </Grid>

        <controls:ChatPanel
            x:Name="ChatPanel"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            DisableInternalSendFlow="True"
            ShowTitleBar="False"
            ShowPresetSelector="False"
            ShowProfileSelector="False"
            Theme="System"
            Placeholder="Ask Claude anything..." />
    </Grid>

</Window>
