<Window
    x:Class="AnthropicSdkSample.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:FieldCure.AssistStudio.Controls"
    Title="Anthropic SDK Sample">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (right padding reserves space for caption buttons) -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="48"
              Padding="16,0,140,0"
              AutomationProperties.AutomationId="AppTitleBar"
              AutomationProperties.Name="Application title bar">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Name="AppTitleText"
                Grid.Column="0"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                Text="Anthropic SDK Sample"
                Style="{StaticResource CaptionTextBlockStyle}"
                AutomationProperties.AutomationId="AppTitleText"
                AutomationProperties.Name="Application title" />

            <ComboBox
                x:Name="ModelComboBox"
                Grid.Column="2"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                BorderThickness="0"
                Background="Transparent"
                SelectionChanged="OnModelSelectionChanged"
                AutomationProperties.AutomationId="ModelSelector"
                AutomationProperties.Name="Claude model"
                AutomationProperties.HelpText="Selects which Claude model handles the conversation" />

            <Button
                x:Name="ThemeToggleButton"
                Grid.Column="3"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                Click="OnThemeToggleClick"
                ToolTipService.ToolTip="Toggle theme"
                AutomationProperties.AutomationId="ThemeToggleButton"
                AutomationProperties.Name="Toggle theme"
                Style="{StaticResource DefaultButtonStyle}">
                <FontIcon
                    x:Name="ThemeToggleIcon"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xE708;" />
            </Button>

            <Button
                x:Name="ExportButton"
                Grid.Column="4"
                Content="Export"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                IsEnabled="False"
                Click="OnExportClick"
                ToolTipService.ToolTip="Copy conversation as Markdown"
                AutomationProperties.AutomationId="ExportConversationButton"
                AutomationProperties.Name="Export conversation to Markdown"
                Style="{StaticResource DefaultButtonStyle}" />

            <Button
                x:Name="ResetApiKeyButton"
                Grid.Column="5"
                Content="Reset API Key"
                VerticalAlignment="Center"
                Click="OnResetKeyClicked"
                AutomationProperties.AutomationId="ResetApiKeyButton"
                AutomationProperties.Name="Reset API key"
                AutomationProperties.HelpText="Clears the stored Anthropic API key and prompts for a new one"
                Style="{StaticResource DefaultButtonStyle}" />
        </Grid>

        <TeachingTip
            x:Name="ExportTip"
            Target="{x:Bind ExportButton}"
            IsLightDismissEnabled="True"
            AutomationProperties.AutomationId="ExportTip"
            AutomationProperties.Name="Export result notification" />

        <controls:ChatPanel
            x:Name="ChatPanel"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            DisableInternalSendFlow="True"
            ShowTitleBar="False"
            ShowPresetSelector="False"
            ShowProfileSelector="False"
            Theme="System"
            Placeholder="Ask Claude anything..." />
    </Grid>

</Window>
